        // =====================================================================
        // STAGE 7: SonarQube Analysis
        // =====================================================================
        stage('SonarQube Analysis') {
            when { expression { params.RUN_SONARQUBE } }
            steps {
                script {
                    def projectKey = params.SONAR_PROJECT_KEY?.trim() ?: (env.JOB_NAME ?: 'devsecops-project')
                    def hasSonarScanner = sh(script: 'command -v sonar-scanner', returnStatus: true) == 0
                    def hasSonarToken   = env.SONAR_TOKEN?.trim()?.length() > 0

                    if (!hasSonarScanner || !hasSonarToken) {
                        sh """
