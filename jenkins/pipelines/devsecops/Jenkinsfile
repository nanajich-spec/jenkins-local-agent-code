        // =====================================================================
        // STAGE 8: Build Application (per module, Makefile-first, language fallback)
        // =====================================================================
        stage('Build Application') {
            steps {
                sh """
export REPORTS_DIR='${REPORTS_DIR}'
export WORKSPACE='${WORKSPACE}'
export REGISTRY='${REGISTRY}'
export IMAGE_TAG='${params.IMAGE_TAG ?: 'latest'}'
export IMAGE_NAME='${params.IMAGE_NAME ?: ''}'
python3 <<'BUILD_EOF'
import json, subprocess, os

WORKSPACE  = os.environ['WORKSPACE']
REPORTS_DIR= os.environ['REPORTS_DIR']
REGISTRY   = os.environ.get('REGISTRY', '')
IMAGE_TAG  = os.environ.get('IMAGE_TAG', 'latest')
IMAGE_NAME = os.environ.get('IMAGE_NAME', '')
modules    = json.loads(open(os.path.join(REPORTS_DIR, 'modules.json')).read())

def run(cmd, cwd=None):
    print(f'  \\$ {cmd}')
    return subprocess.run(cmd, shell=True, cwd=cwd or WORKSPACE).returncode

for key, m in modules.items():
    lang     = m['language']
    d        = os.path.join(WORKSPACE, m['dir']) if m['dir'] else WORKSPACE
    safe     = key.replace('/', '-')
    makefiles= m.get('makefiles', [])
    print(f'\\n{"="*60}')
    print(f'  [build] Module: {key}  lang={lang}  dir={m["dir"] or "."}')
    print(f'{"="*60}')

    if makefiles:
        for mf in makefiles:
            mf_dir  = os.path.join(WORKSPACE, mf['dir']) if mf['dir'] else WORKSPACE
            target  = mf.get('build_target') or mf.get('docker_target', '')
            print(f'  Makefile: {mf["path"]}  target: {target or "(default)"}')
            img = f'{REGISTRY}/{IMAGE_NAME}:{IMAGE_TAG}' if IMAGE_NAME else ''
            # Try with image args first, then without (for Makefiles that don't accept them)
            if target:
                rc = run(
                    f'make -f "{os.path.join(WORKSPACE, mf["path"])}" {target} '
                    f'IMAGE_NAME="{img}" REGISTRY="{REGISTRY}" TAG="{IMAGE_TAG}"',
                    cwd=mf_dir
                )
                if rc != 0:
                    run(f'make -f "{os.path.join(WORKSPACE, mf["path"])}" {target}',
                        cwd=mf_dir)
            else:
                rc = run(f'make -f "{os.path.join(WORKSPACE, mf["path"])}" build '
                         f'IMAGE_NAME="{img}" REGISTRY="{REGISTRY}" TAG="{IMAGE_TAG}"',
                         cwd=mf_dir)
                if rc != 0:
                    run(f'make -f "{os.path.join(WORKSPACE, mf["path"])}"', cwd=mf_dir)
    else:
        # No Makefile — run language-specific build
        if lang == 'python':
            if os.path.isfile(os.path.join(d, 'pyproject.toml')):
                run('pip install --break-system-packages build && python3 -m build', cwd=d)
            elif os.path.isfile(os.path.join(d, 'setup.py')):
                run('python3 setup.py bdist_wheel', cwd=d)
            else:
                print('  [INFO] Python script project — no wheel build needed')
        elif lang == 'java-maven':
            run('mvn package -DskipTests -q', cwd=d)
        elif lang == 'java-gradle':
            run('./gradlew build -x test 2>/dev/null || gradle build -x test', cwd=d)
        elif lang in ('nodejs', 'react', 'angular', 'vue'):
            pkg = open(os.path.join(d, 'package.json')).read() if os.path.isfile(os.path.join(d, 'package.json')) else ''
            if '"build"' in pkg:
                run('npm run build', cwd=d)
            else:
                print('  [INFO] No "build" script in package.json')
        elif lang == 'go':
            run(f'CGO_ENABLED=0 go build -o "{REPORTS_DIR}/app-{safe}" ./...', cwd=d)
        elif lang == 'dotnet':
            run('dotnet build --configuration Release', cwd=d)

print()
print('  [OK] Build stage complete for all modules')
BUILD_EOF
"""
            }
        }

        // =====================================================================
        // STAGE 9: Docker / Container Build — builds image for EACH Dockerfile
        //          discovered across ALL modules (Makefile docker target first)
        // =====================================================================
        stage('Docker Build & Push') {
            steps {
                script {
                    def imageName = params.IMAGE_NAME?.trim()
                    env.BUILT_IMAGE = ''

                    if (!imageName || imageName == 'none') {
                        sh """
echo "======================================================================"
echo "  [WARNING] IMAGE_NAME is not set — Docker build SKIPPED"
echo "  Set the IMAGE_NAME parameter to enable container image build."
echo "======================================================================"
echo 'IMAGE_NAME not set — Docker build skipped' >> '${REPORTS_DIR}/pipeline-warnings.txt'
"""
                        return
                    }
                }

                sh """
export REPORTS_DIR='${REPORTS_DIR}'
export WORKSPACE='${WORKSPACE}'
export REGISTRY='${REGISTRY}'
export IMAGE_NAME='${params.IMAGE_NAME ?: ''}'
export IMAGE_TAG='${params.IMAGE_TAG ?: 'latest'}'
python3 <<'DOCKER_EOF'
import json, subprocess, os

WORKSPACE  = os.environ['WORKSPACE']
REPORTS_DIR= os.environ['REPORTS_DIR']
REGISTRY   = os.environ.get('REGISTRY', '')
IMAGE_NAME = os.environ.get('IMAGE_NAME', '')
IMAGE_TAG  = os.environ.get('IMAGE_TAG', 'latest')
modules    = json.loads(open(os.path.join(REPORTS_DIR, 'modules.json')).read())
built_images = []

def run(cmd, cwd=None):
    print(f'  \\$ {cmd}')
    return subprocess.run(cmd, shell=True, cwd=cwd or WORKSPACE).returncode

def build_image(tag, dockerfile, context):
    """Try podman first, then docker."""
    for rt in ('podman', 'docker'):
        if subprocess.run(f'command -v {rt}', shell=True,
                          stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).returncode == 0:
            push_flag = '--tls-verify=false' if rt == 'podman' else ''
            rc = run(f'{rt} build -t "{tag}" -f "{dockerfile}" "{context}"')
            if rc == 0:
                run(f'{rt} push "{tag}" {push_flag}')
                return True
    print('  [WARN] No container runtime (podman/docker) found on agent')
    return False

for key, m in modules.items():
    d        = os.path.join(WORKSPACE, m['dir']) if m['dir'] else WORKSPACE
    makefiles= m.get('makefiles', [])
    dfs      = m.get('dockerfiles', [])
    safe     = key.replace('/', '-')

    if not dfs and not any(mf.get('docker_target') for mf in makefiles):
        continue

    print(f'\\n{"="*60}')
    print(f'  [docker] Module: {key}  dockerfiles={dfs}')
    print(f'{"="*60}')

    # Determine image tag: base-name from module key
    tag_name = IMAGE_NAME if key == 'root' else f'{IMAGE_NAME}-{safe}'
    full_tag = f'{REGISTRY}/{tag_name}:{IMAGE_TAG}' if REGISTRY else f'{tag_name}:{IMAGE_TAG}'
    img_args = f'IMAGE_NAME="{full_tag}" REGISTRY="{REGISTRY}" TAG="{IMAGE_TAG}"'

    # Prefer Makefile docker target
    mk_built = False
    for mf in makefiles:
        dt = mf.get('docker_target', '')
        if not dt: continue
        mf_dir = os.path.join(WORKSPACE, mf['dir']) if mf['dir'] else WORKSPACE
        print(f'  Makefile docker target: {mf["path"]} → {dt}')
        rc = run(f'make -f "{os.path.join(WORKSPACE, mf["path"])}" {dt} {img_args}',
                 cwd=mf_dir)
        if rc != 0:
            rc = run(f'make -f "{os.path.join(WORKSPACE, mf["path"])}" {dt}', cwd=mf_dir)
        if rc == 0:
            mk_built = True
            built_images.append(full_tag)
            break

    # Fall back to direct docker/podman build for each Dockerfile
    if not mk_built:
        for idx, df in enumerate(dfs):
            df_abs = os.path.join(WORKSPACE, df)
            ctx    = os.path.dirname(df_abs)
            # For multi-Dockerfile modules, suffix the image name
            img_tag = full_tag if idx == 0 else f'{REGISTRY}/{tag_name}-{os.path.basename(os.path.dirname(df))}:{IMAGE_TAG}'
            print(f'  Building from: {df} → {img_tag}')
            if build_image(img_tag, df_abs, ctx):
                built_images.append(img_tag)

# Write built images list for downstream use (Trivy scan)
with open(os.path.join(REPORTS_DIR, 'built-images.txt'), 'w') as f:
    f.write('\\n'.join(built_images))
if built_images:
    print(f'\\n  [OK] Built images: {built_images}')
else:
    print('  [WARN] No images were successfully built')
DOCKER_EOF
"""

                script {
                    // Set BUILT_IMAGE to first built image for Trivy scan
                    def builtFile = "${REPORTS_DIR}/built-images.txt"
                    if (fileExists(builtFile)) {
                        def lines = readFile(builtFile).trim().split('\n')
                        env.BUILT_IMAGE = lines ? lines[0].trim() : ''
                    }
                    if (env.BUILT_IMAGE) {
                        echo "[OK] Primary image for Trivy scan: ${env.BUILT_IMAGE}"
                    }
                }
            }
        }

        // =====================================================================
        // STAGE 10: Trivy Image Scan
        // =====================================================================
        stage('Trivy Image Scan') {
            when { expression { params.RUN_TRIVY_SCAN && (env.BUILT_IMAGE?.trim()) } }
            steps {
                sh """
                    echo "=== Trivy Image Scan: ${env.BUILT_IMAGE} ==="
                    trivy image \
                        --severity '${SCAN_SEVERITY}' \
                        --format json \
                        --output '${REPORTS_DIR}/trivy/trivy-image-scan.json' \
                        --timeout 15m \
                        '${env.BUILT_IMAGE}' 2>/dev/null || \
                    echo '{"Results":[],"SchemaVersion":2}' > '${REPORTS_DIR}/trivy/trivy-image-scan.json'

                    trivy image \
                        --severity '${SCAN_SEVERITY}' \
                        --format table \
                        --timeout 15m \
                        '${env.BUILT_IMAGE}' 2>/dev/null | tee '${REPORTS_DIR}/trivy/trivy-image-scan.txt' || true

                    echo "=== Trivy Image SBOM ==="
                    trivy image \
                        --format cyclonedx \
                        --output '${REPORTS_DIR}/sbom/sbom-trivy-image.json' \
                        '${env.BUILT_IMAGE}' 2>/dev/null || true
                """
                sh '''
python3 <<'PYEOF'
import json, os
f = os.path.join(os.environ.get("REPORTS_DIR", "."), "trivy", "trivy-image-scan.json")
try:
    with open(f) as fh: data = json.load(fh)
    results = data.get("Results", [])
    crit = sum(1 for r in results for v in (r.get("Vulnerabilities") or []) if v.get("Severity") == "CRITICAL")
    high = sum(1 for r in results for v in (r.get("Vulnerabilities") or []) if v.get("Severity") == "HIGH")
    print(f"  [Trivy Image] CRITICAL={crit}  HIGH={high}")
except Exception as e:
    print(f"  [Trivy Image] Report not available: {e}")
PYEOF
'''
            }
        }

        // =====================================================================
        // STAGE 11: SAST · Filesystem Scan · Secret Detection
