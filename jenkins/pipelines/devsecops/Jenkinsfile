"""
                        sh '''
python3 <<'PYEOF'
import json, os, re, xml.etree.ElementTree as ET
r = os.environ.get("REPORTS_DIR", ".")
report = {"sonarqube_available": False, "local_analysis": True, "quality_metrics": {}}
for name, file in [("bandit","bandit-report.json"),("flake8","flake8-report.txt"),("pylint","pylint-report.txt"),("eslint","eslint-report.json")]:
    fpath = os.path.join(r, file)
    if not os.path.exists(fpath): continue
    try:
        if name == "bandit":
            with open(fpath) as f: data = json.load(f)
            results = data.get("results", [])
            report["quality_metrics"]["bandit_total"] = len(results)
            report["quality_metrics"]["bandit_high"] = sum(1 for x in results if x.get("issue_severity") == "HIGH")
        elif name == "flake8":
            with open(fpath) as f: report["quality_metrics"]["flake8_issues"] = len([l for l in f if l.strip()])
        elif name == "pylint":
            with open(fpath) as f: content = f.read()
            m = re.search(r"rated at ([0-9.]+)", content)
            if m: report["quality_metrics"]["pylint_score"] = float(m.group(1))
        elif name == "eslint":
            with open(fpath) as f: data = json.load(f)
            report["quality_metrics"]["eslint_errors"] = sum(x.get("errorCount",0) for x in data)
    except: pass
cov = os.path.join(r, "coverage.xml")
if os.path.exists(cov):
    try:
        root = ET.parse(cov).getroot()
        report["quality_metrics"]["coverage_pct"] = round(float(root.attrib.get("line-rate",0))*100, 1)
    except: pass
os.makedirs(os.path.join(r,"sonarqube"), exist_ok=True)
with open(os.path.join(r,"sonarqube","local-quality-report.json"), "w") as f:
    json.dump(report, f, indent=2)
print("  Local quality metrics:")
for k,v in report["quality_metrics"].items(): print(f"    {k}: {v}")
PYEOF
'''
                        return
                    }

                    def langParams = ''
                    switch (env.DETECTED_LANG) {
                        case 'python':
