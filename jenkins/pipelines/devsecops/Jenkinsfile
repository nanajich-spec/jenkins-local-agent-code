python3 <<'PYEOF'
import json, os, glob
sbom_dir = os.path.join(os.environ.get("REPORTS_DIR", "."), "sbom")
total = 0
jfiles = sorted(glob.glob(os.path.join(sbom_dir, "sbom-*.json")))
tfiles = sorted(glob.glob(os.path.join(sbom_dir, "sbom-*.txt")) +
                glob.glob(os.path.join(sbom_dir, "*-audit-*.txt")))
