                                --format json \
                                --output '${REPORTS_DIR}/trivy/trivy-sca.json' \
                                '${WORKSPACE}' 2>/dev/null || \
                            echo '{"Results":[]}' > '${REPORTS_DIR}/trivy/trivy-sca.json'

                            trivy fs \
                                --scanners vuln,license \
                                --severity '${SCAN_SEVERITY}' \
                                --format table \
                                '${WORKSPACE}' 2>/dev/null | tee '${REPORTS_DIR}/trivy/trivy-sca.txt' || true
                        """
                    }
                }
                stage('Grype SCA') {
                    when { expression { params.RUN_GRYPE && sh(script: 'command -v grype', returnStatus: true) == 0 } }
                    steps {
                        sh """
                            grype 'dir:${WORKSPACE}' --output json \
                                --file '${REPORTS_DIR}/grype-sca.json' 2>/dev/null || true
                            grype 'dir:${WORKSPACE}' --output table \
                                | tee '${REPORTS_DIR}/grype-sca.txt' 2>/dev/null || true
                        """
                    }
