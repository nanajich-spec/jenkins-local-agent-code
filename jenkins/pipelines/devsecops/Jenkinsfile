// =============================================================================
// Jenkinsfile — Comprehensive DevSecOps Pipeline
// =============================================================================
// Full CI/CD + Security + SBOM + Quality Pipeline:
//
//  ┌──────────────────────────────────────────────────────────────────────────┐
//  │  PIPELINE STAGES:                                                        │
//  │   1.  Checkout & Language Detection                                      │
//  │   2.  Tool Verification                                                  │
//  │   3.  Install Dependencies                                               │
//  │   4.  Lint & Code Quality                                                │
//  │   5.  Unit Testing + Coverage                                            │
//  │   6.  Integration Tests (optional)                                       │
//  │   7.  CycloneDX SBOM Generation (Java/Python/Node/React/Go/.NET)        │
//  │   8.  SonarQube Analysis                                                 │
//  │   9.  Build Application                                                  │
//  │  10.  Docker Build & Push                                                │
//  │  11.  Trivy Image Scan                                                   │
//  │  12.  SAST & Secret Detection                                            │
//  │  13.  SCA — Dependency Scan                                              │
//  │  14.  Dockerfile Lint (Hadolint)                                         │
//  │  15.  ShellCheck                                                         │
//  │  16.  K8s Manifest Security Scan                                         │
//  │  17.  Security Gate                                                      │
//  │  18.  Deploy to K8s (optional)                                           │
//  │  19.  Comprehensive Final Report                                         │
//  │       ├── Unit Test Report                                               │
//  │       ├── Coverage Report                                                │
//  │       ├── SonarQube Report                                               │
//  │       ├── Trivy Report                                                   │
//  │       ├── SBOM Report                                                    │
//  │       ├── Secret Detection Report                                        │
//  │       ├── Other Reports (Hadolint, ShellCheck, Grype, Bandit etc.)      │
//  │       └── Final Comprehensive Report (HTML + TXT + JSON)                │
//  │           ├── HIGH / CRITICAL / BLOCKER issues                          │
//  │           ├── Test Coverage overview                                     │
//  │           └── SonarQube overview                                         │
//  └──────────────────────────────────────────────────────────────────────────┘
//
//  Supports: Python, Java (Maven/Gradle), Node.js, React, Angular, Go, .NET
//  Run: Single command scans root folder completely
// =============================================================================

pipeline {
    agent { label params.AGENT_LABEL ?: 'local-security-agent' }

    options {
        buildDiscarder(logRotator(numToKeepStr: '20'))
        timestamps()
        timeout(time: params.TIMEOUT_MINUTES?.toInteger() ?: 120, unit: 'MINUTES')
        ansiColor('xterm')
    }

    environment {
        REGISTRY           = "${params.REGISTRY ?: '132.186.17.22:5000'}"
        REPORTS_DIR        = "${WORKSPACE}/pipeline-reports"
        COVERAGE_THRESHOLD = "${params.COVERAGE_THRESHOLD ?: '70'}"
        SCAN_SEVERITY      = 'CRITICAL,HIGH'
        TRIVY_CACHE_DIR    = "${WORKSPACE}/.trivy-cache"
    }

    parameters {
        // ── Project Settings ──
        string(name: 'GIT_REPO',             defaultValue: '',               description: 'Git repo URL (leave blank for workspace/SCM)')
        string(name: 'GIT_BRANCH',           defaultValue: 'main',           description: 'Branch to build')
        choice(name: 'LANGUAGE',             choices: ['auto', 'python', 'java-maven', 'java-gradle', 'nodejs', 'react', 'angular', 'go', 'dotnet'], description: 'Project language (auto-detect if unsure)')

        // ── Docker Settings ──
        string(name: 'IMAGE_NAME',           defaultValue: '',               description: 'Docker image name (leave blank to skip Docker)')
        string(name: 'IMAGE_TAG',            defaultValue: 'latest',         description: 'Docker image tag')
        string(name: 'REGISTRY',             defaultValue: '132.186.17.22:5000', description: 'Container registry URL')
        string(name: 'DOCKERFILE_PATH',      defaultValue: 'Dockerfile',     description: 'Dockerfile path (or Containerfile)')

        // ── Test Settings ──
        booleanParam(name: 'RUN_UNIT_TESTS',      defaultValue: true,   description: 'Run unit tests')
        booleanParam(name: 'RUN_INTEGRATION_TESTS', defaultValue: false, description: 'Run integration tests')
        string(name: 'COVERAGE_THRESHOLD',         defaultValue: '70',   description: 'Minimum code coverage %')
        string(name: 'PYTEST_ARGS',                defaultValue: '',     description: 'Extra pytest arguments')

        // ── Security Settings ──
        booleanParam(name: 'RUN_TRIVY_SCAN',       defaultValue: true,   description: 'Run Trivy image & filesystem scan')
        booleanParam(name: 'RUN_SECRET_DETECTION',  defaultValue: true,   description: 'Run secret detection')
        booleanParam(name: 'RUN_K8S_MANIFEST_SCAN', defaultValue: true,   description: 'Scan K8s deployment manifests')
        booleanParam(name: 'RUN_DOCKERFILE_LINT',    defaultValue: true,   description: 'Lint Dockerfile with Hadolint')
        booleanParam(name: 'RUN_OWASP_CHECK',       defaultValue: false,  description: 'Run OWASP Dependency-Check')
        booleanParam(name: 'RUN_GRYPE',              defaultValue: false,  description: 'Run Grype vulnerability scan')
        booleanParam(name: 'FAIL_ON_CRITICAL',       defaultValue: true,   description: 'Fail build on CRITICAL vulnerabilities')

        // ── SBOM Settings ──
        booleanParam(name: 'GENERATE_SBOM',         defaultValue: true,   description: 'Generate CycloneDX SBOM')

        // ── SonarQube Settings ──
        booleanParam(name: 'RUN_SONARQUBE',          defaultValue: true,   description: 'Run SonarQube analysis')
        string(name: 'SONAR_PROJECT_KEY',            defaultValue: '',     description: 'SonarQube project key (auto if blank)')

        // ── Deploy Settings ──
        booleanParam(name: 'DEPLOY_TO_K8S',        defaultValue: false,  description: 'Deploy to Kubernetes after scan')
        string(name: 'K8S_NAMESPACE',              defaultValue: '',     description: 'Kubernetes namespace')
        string(name: 'K8S_MANIFESTS_DIR',           defaultValue: 'cat-deployments', description: 'Path to K8s manifest directory')

        // ── Agent ──
        string(name: 'AGENT_LABEL',               defaultValue: 'local-security-agent', description: 'Jenkins agent label')
        string(name: 'TIMEOUT_MINUTES',            defaultValue: '120',  description: 'Pipeline timeout (minutes)')
    }

    stages {

        // =====================================================================
        // STAGE 1: Checkout & Language Detection
        // =====================================================================
        stage('Checkout & Detect Language') {
            steps {
                script {
                    if (params.GIT_REPO?.trim()) {
                        checkout([
                            $class: 'GitSCM',
                            branches: [[name: "*/${params.GIT_BRANCH}"]],
                            userRemoteConfigs: [[url: params.GIT_REPO]],
                            extensions: [[$class: 'CloneOption', depth: 1, shallow: true]]
                        ])
                    }

                    sh "mkdir -p '${REPORTS_DIR}' '${REPORTS_DIR}/sbom' '${REPORTS_DIR}/sonarqube'"

                    env.DETECTED_LANG = params.LANGUAGE
                    if (params.LANGUAGE == 'auto') {
                        env.DETECTED_LANG = detectLanguage()
                    }

                    env.HAS_DOCKERFILE = fileExists(params.DOCKERFILE_PATH ?: 'Dockerfile') || fileExists('Containerfile') ? 'true' : 'false'
                    env.HAS_MAKEFILE   = fileExists('Makefile') ? 'true' : 'false'
                    env.HAS_K8S_MANIFESTS = sh(script: "find '${params.K8S_MANIFESTS_DIR ?: 'cat-deployments'}' -name '*.yml' -o -name '*.yaml' 2>/dev/null | head -1", returnStdout: true).trim() ? 'true' : 'false'
                    env.PIPELINE_START = sh(script: 'date +%s', returnStdout: true).trim()

                    echo """
╔══════════════════════════════════════════════════════════════╗
║    Comprehensive DevSecOps Pipeline — Configuration          ║
╠══════════════════════════════════════════════════════════════╣
║  Language:        ${env.DETECTED_LANG.padRight(40)}║
║  Branch:          ${(params.GIT_BRANCH ?: 'workspace').padRight(40)}║
║  Docker Image:    ${(params.IMAGE_NAME ?: 'N/A').padRight(40)}║
║  Dockerfile:      ${env.HAS_DOCKERFILE.padRight(40)}║
║  K8s Manifests:   ${env.HAS_K8S_MANIFESTS.padRight(40)}║
║  Unit Tests:      ${params.RUN_UNIT_TESTS.toString().padRight(40)}║
║  SBOM:            ${params.GENERATE_SBOM.toString().padRight(40)}║
║  SonarQube:       ${params.RUN_SONARQUBE.toString().padRight(40)}║
║  Trivy Scan:      ${params.RUN_TRIVY_SCAN.toString().padRight(40)}║
║  Fail on Crit:    ${params.FAIL_ON_CRITICAL.toString().padRight(40)}║
╚══════════════════════════════════════════════════════════════╝
                    """
                }
            }
        }

        // =====================================================================
        // STAGE 2: Tool Verification
        // =====================================================================
        stage('Verify Tools') {
            steps {
                sh '''
                    echo "╔══════════════════════════════════════════════════════════════╗"
                    echo "║              Tool Verification                               ║"
                    echo "╠══════════════════════════════════════════════════════════════╣"
                    check_tool() {
                        local name="$1" cmd="$2"
                        if command -v "$cmd" &>/dev/null; then
                            VER=$($cmd --version 2>&1 | head -1)
                            printf "║  %-18s ✅  %s\\n" "$name" "$VER"
                        else
                            printf "║  %-18s ❌  Not installed\\n" "$name"
                        fi
                    }
                    check_tool "Python"       "python3"
                    check_tool "pip"          "pip"
                    check_tool "Node.js"      "node"
                    check_tool "npm"          "npm"
                    check_tool "Go"           "go"
                    check_tool "Java"         "java"
                    check_tool "Maven"        "mvn"
                    check_tool "Trivy"        "trivy"
                    check_tool "Podman"       "podman"
                    check_tool "Hadolint"     "hadolint"
                    check_tool "ShellCheck"   "shellcheck"
                    check_tool "Grype"        "grype"
                    check_tool "Kubesec"      "kubesec"
                    check_tool "kubectl"      "kubectl"
                    check_tool "SonarScanner" "sonar-scanner"
                    check_tool "CycloneDX"    "cyclonedx-py"
                    echo "╚══════════════════════════════════════════════════════════════╝"
                '''
            }
        }

        // =====================================================================
        // STAGE 3: Install Dependencies
        // =====================================================================
        stage('Install Dependencies') {
            steps {
                script {
                    switch (env.DETECTED_LANG) {
                        case 'python':
                            sh '''
                                echo "=== Installing Python Dependencies ==="
                                python3 -m pip install --upgrade pip 2>/dev/null || true
                                if [ -f "requirements.txt" ]; then pip install -r requirements.txt 2>/dev/null || true; fi
                                if [ -f "requirements-dev.txt" ]; then pip install -r requirements-dev.txt 2>/dev/null || true; fi
                                if [ -f "setup.py" ] || [ -f "pyproject.toml" ]; then
                                    pip install -e ".[dev,test]" 2>/dev/null || pip install -e . 2>/dev/null || true
                                fi
                                pip install pytest pytest-cov pytest-html pytest-xdist \
                                    flake8 black mypy bandit safety pylint \
                                    cyclonedx-bom cyclonedx-py pip-audit 2>/dev/null || true
                            '''
                            break
                        case 'java-maven':
                            sh 'mvn dependency:resolve -q 2>/dev/null || true'
                            break
                        case 'java-gradle':
                            sh '''
                                chmod +x gradlew 2>/dev/null || true
                                ./gradlew dependencies --quiet 2>/dev/null || gradle dependencies --quiet 2>/dev/null || true
                            '''
                            break
                        case ['nodejs', 'react', 'angular']:
                            sh '''
                                if [ -f "yarn.lock" ]; then
                                    yarn install --frozen-lockfile 2>/dev/null || yarn install
                                elif [ -f "package-lock.json" ] || [ -f "package.json" ]; then
                                    npm ci 2>/dev/null || npm install
                                fi
                                npm install -g @cyclonedx/cyclonedx-npm 2>/dev/null || true
                            '''
                            break
                        case 'go':
                            sh '''
                                go mod download && go mod verify
                                go install github.com/CycloneDX/cyclonedx-gomod/cmd/cyclonedx-gomod@latest 2>/dev/null || true
                            '''
                            break
                        case 'dotnet':
                            sh '''
                                dotnet restore
                                dotnet tool install --global CycloneDX 2>/dev/null || true
                            '''
                            break
                        default:
                            echo "No dependency installation for: ${env.DETECTED_LANG}"
                    }
                }
            }
        }

        // =====================================================================
        // STAGE 4: Lint & Code Quality
        // =====================================================================
        stage('Lint & Code Quality') {
            steps {
                script {
                    switch (env.DETECTED_LANG) {
                        case 'python':
                            sh '''
                                echo "--- Flake8 ---"
                                flake8 . --max-line-length=120 \
                                    --exclude=.venv,venv,__pycache__,migrations,.trivy-cache,pipeline-reports \
                                    --output-file="${REPORTS_DIR}/flake8-report.txt" 2>/dev/null || true
                                echo "--- Black ---"
                                black --check --diff . --exclude '/(.venv|venv|__pycache__|.trivy-cache)/' 2>/dev/null || echo "Formatting issues (non-blocking)"
                                echo "--- Pylint ---"
                                find . -name "*.py" -not -path "./.venv/*" -not -path "./venv/*" -not -path "./.trivy-cache/*" -not -path "./pipeline-reports/*" \
                                    | head -20 | xargs pylint --output-format=text --score=yes \
                                    > "${REPORTS_DIR}/pylint-report.txt" 2>/dev/null || true
                                echo "--- Bandit ---"
                                bandit -r . -f json -o "${REPORTS_DIR}/bandit-report.json" \
                                    --exclude .venv,venv,tests,test,.trivy-cache,pipeline-reports 2>/dev/null || true
                            '''
                            break
                        case 'java-maven':
                            sh '''
                                mvn checkstyle:check -q 2>/dev/null || echo "Checkstyle issues (non-blocking)"
                                mvn spotbugs:check -q 2>/dev/null || echo "SpotBugs not configured"
                            '''
                            break
                        case 'java-gradle':
                            sh '''
                                ./gradlew checkstyleMain 2>/dev/null || echo "Checkstyle not configured"
                                ./gradlew spotbugsMain 2>/dev/null || echo "SpotBugs not configured"
                            '''
                            break
                        case ['nodejs', 'react', 'angular']:
                            sh '''
                                if [ -f "node_modules/.bin/eslint" ]; then
                                    npx eslint . --format json --output-file "${REPORTS_DIR}/eslint-report.json" 2>/dev/null || true
                                fi
                                if [ -f "node_modules/.bin/prettier" ]; then
                                    npx prettier --check "src/**/*.{js,jsx,ts,tsx}" 2>/dev/null || echo "Format issues found"
                                fi
                            '''
                            break
                        case 'go':
                            sh '''
                                go vet ./... 2>&1 | tee "${REPORTS_DIR}/govet-report.txt" || true
                                if command -v golangci-lint &>/dev/null; then
                                    golangci-lint run --out-format json > "${REPORTS_DIR}/golangci-lint.json" 2>/dev/null || true
                                fi
                            '''
                            break
                        case 'dotnet':
                            sh 'dotnet format --verify-no-changes 2>/dev/null || echo "Format issues found"'
                            break
                    }
                }
            }
        }

        // =====================================================================
        // STAGE 5: Unit Testing + Coverage
        // =====================================================================
        stage('Unit Testing & Coverage') {
            when { expression { params.RUN_UNIT_TESTS } }
            steps {
                script {
                    // ── Check if test folders/files exist for the detected language ──
                    def testsDetected = false
                    def testFolderMsg = ""

                    switch (env.DETECTED_LANG) {
                        case 'python':
                            testsDetected = fileExists('tests') || fileExists('test') ||
                                sh(script: "find . -maxdepth 3 -name 'test_*.py' -o -name '*_test.py' | head -1", returnStdout: true).trim()
                            testFolderMsg = "Expected: tests/ or test/ directory, or test_*.py / *_test.py files"
                            break
                        case 'java-maven':
                        case 'java-gradle':
                            testsDetected = fileExists('src/test') ||
                                sh(script: "find . -maxdepth 5 -name '*Test.java' -o -name '*Tests.java' | head -1", returnStdout: true).trim()
                            testFolderMsg = "Expected: src/test/java/ directory, or *Test.java / *Tests.java files"
                            break
                        case 'nodejs':
                        case 'react':
                        case 'angular':
                        case 'vue':
                            testsDetected = fileExists('test') || fileExists('tests') || fileExists('__tests__') || fileExists('spec') ||
                                sh(script: "find . -maxdepth 4 \\( -name '*.test.js' -o -name '*.test.ts' -o -name '*.test.jsx' -o -name '*.test.tsx' -o -name '*.spec.js' -o -name '*.spec.ts' \\) ! -path '*/node_modules/*' | head -1", returnStdout: true).trim()
                            testFolderMsg = "Expected: test/, tests/, __tests__/, or *.test.js / *.spec.ts files"
                            break
                        case 'go':
                            testsDetected = sh(script: "find . -maxdepth 5 -name '*_test.go' | head -1", returnStdout: true).trim()
                            testFolderMsg = "Expected: *_test.go files"
                            break
                        case 'dotnet':
                            testsDetected = fileExists('test') || fileExists('tests') ||
                                sh(script: "find . -maxdepth 4 -name '*Test*.csproj' -o -name '*Tests*.csproj' | head -1", returnStdout: true).trim()
                            testFolderMsg = "Expected: test/, tests/ directory, or *Test*.csproj / *Tests*.csproj project"
                            break
                        default:
                            testsDetected = fileExists('test') || fileExists('tests')
                            testFolderMsg = "Expected: test/ or tests/ directory"
                    }

                    if (!testsDetected) {
                        echo """
╔══════════════════════════════════════════════════════════════╗
║  ⚠  NO TESTS FOLDER DETECTED                                ║
╠══════════════════════════════════════════════════════════════╣
║  Language: ${env.DETECTED_LANG}
║  ${testFolderMsg}
║                                                              ║
║  No test directory or test files found in the project.       ║
║  Please write test cases to enable automated testing         ║
║  in the pipeline.                                            ║
║                                                              ║
║  Skipping unit test execution.                               ║
╚══════════════════════════════════════════════════════════════╝
                        """
                        sh "echo 'NO_TESTS_FOUND' > '${REPORTS_DIR}/test-status.txt'"
                        return
                    }

                    echo "=== Tests folder detected — running ${env.DETECTED_LANG} unit tests ==="

                    switch (env.DETECTED_LANG) {
                        case 'python':
                            def pyTestDir = fileExists('tests') ? 'tests/' : (fileExists('test') ? 'test/' : '.')
                            sh """
                                echo "╔══════════════════════════════════════════════════════════════╗"
                                echo "║        Unit Testing — pytest + Coverage                      ║"
                                echo "╚══════════════════════════════════════════════════════════════╝"
                                python3 -m pytest ${pyTestDir} \
                                    --junitxml="${REPORTS_DIR}/pytest-unit-results.xml" \
                                    --html="${REPORTS_DIR}/pytest-report.html" --self-contained-html \
                                    --cov=. \
                                    --cov-report=xml:"${REPORTS_DIR}/coverage.xml" \
                                    --cov-report=html:"${REPORTS_DIR}/htmlcov" \
                                    --cov-report=term-missing \
                                    --cov-fail-under=${COVERAGE_THRESHOLD} \
                                    --tb=short -v \
                                    ${params.PYTEST_ARGS ?: ''} \
                                    2>&1 || true

                                if [ -f "${REPORTS_DIR}/pytest-unit-results.xml" ]; then
                                    python3 -c "
import xml.etree.ElementTree as ET
tree = ET.parse('${REPORTS_DIR}/pytest-unit-results.xml')
root = tree.getroot()
tests=int(root.attrib.get('tests',0)); errors=int(root.attrib.get('errors',0))
failures=int(root.attrib.get('failures',0)); skipped=int(root.attrib.get('skipped',0))
passed=tests-errors-failures-skipped; status='PASS' if failures==0 and errors==0 else 'FAIL'
print(f'  Status: {status} | Total: {tests} | Passed: {passed} | Failed: {failures} | Errors: {errors}')
" 2>/dev/null || true
                                fi

                                if [ -f "${REPORTS_DIR}/coverage.xml" ]; then
                                    python3 -c "
import xml.etree.ElementTree as ET
tree = ET.parse('${REPORTS_DIR}/coverage.xml')
root = tree.getroot()
rate=float(root.attrib.get('line-rate',0))*100
print(f'  Coverage: {rate:.1f}% (threshold: ${COVERAGE_THRESHOLD}%)')
" 2>/dev/null || true
                                fi
                            """
                            break
                        case 'java-maven':
                            sh '''
                                mvn test jacoco:report -Dmaven.test.failure.ignore=true 2>/dev/null || echo "Tests completed"
                                cp -r target/surefire-reports/* "${REPORTS_DIR}/" 2>/dev/null || true
                                cp target/site/jacoco/jacoco.xml "${REPORTS_DIR}/jacoco-coverage.xml" 2>/dev/null || true
                                cp -r target/site/jacoco "${REPORTS_DIR}/jacoco-html" 2>/dev/null || true
                            '''
                            break
                        case 'java-gradle':
                            sh '''
                                ./gradlew test jacocoTestReport --continue 2>/dev/null || gradle test jacocoTestReport --continue 2>/dev/null || echo "Tests completed"
                                cp -r build/test-results/test/* "${REPORTS_DIR}/" 2>/dev/null || true
                                cp build/reports/jacoco/test/jacocoTestReport.xml "${REPORTS_DIR}/jacoco-coverage.xml" 2>/dev/null || true
                            '''
                            break
                        case ['nodejs', 'react', 'angular']:
                            sh '''
                                if grep -q '"test"' package.json 2>/dev/null; then
                                    npx jest --ci --coverage \
                                        --coverageDirectory="${REPORTS_DIR}/coverage" \
                                        --coverageReporters=json-summary --coverageReporters=lcov --coverageReporters=text \
                                        --reporters=default --reporters=jest-junit \
                                        2>/dev/null || npm test 2>/dev/null || echo "Tests completed"
                                    cp coverage/lcov.info "${REPORTS_DIR}/lcov.info" 2>/dev/null || true
                                    cp coverage/coverage-summary.json "${REPORTS_DIR}/coverage-summary.json" 2>/dev/null || true
                                fi
                            '''
                            break
                        case 'go':
                            sh '''
                                go test ./... -v -count=1 \
                                    -coverprofile="${REPORTS_DIR}/go-coverage.out" \
                                    -json > "${REPORTS_DIR}/go-test-unit.json" 2>&1 || echo "Tests completed"
                                go tool cover -func="${REPORTS_DIR}/go-coverage.out" 2>/dev/null | tail -5 || true
                                go tool cover -html="${REPORTS_DIR}/go-coverage.out" -o "${REPORTS_DIR}/go-coverage.html" 2>/dev/null || true
                            '''
                            break
                        case 'dotnet':
                            sh '''
                                dotnet test \
                                    --logger "trx;LogFileName=unit-results.trx" \
                                    --collect:"XPlat Code Coverage" \
                                    --results-directory "${REPORTS_DIR}" \
                                    -v normal || echo "Tests completed"
                            '''
                            break
                    }
                }
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: "${REPORTS_DIR}/**/*.xml"
                }
            }
        }

        // =====================================================================
        // STAGE 6: Integration Tests (optional)
        // =====================================================================
        stage('Integration Tests') {
            when { expression { params.RUN_INTEGRATION_TESTS } }
            steps {
                script {
                    // ── Check if integration test folders exist ──
                    def integrationTestsDetected = false
                    switch (env.DETECTED_LANG) {
                        case 'python':
                            integrationTestsDetected = fileExists('tests/integration') || fileExists('test/integration') ||
                                sh(script: "grep -r '@pytest.mark.integration' tests/ test/ 2>/dev/null | head -1", returnStdout: true).trim()
                            break
                        case 'java-maven':
                        case 'java-gradle':
                            integrationTestsDetected = sh(script: "find . -maxdepth 5 -name '*IT.java' -o -name '*IntegrationTest.java' | head -1", returnStdout: true).trim()
                            break
                        case 'nodejs': case 'react': case 'angular':
                            integrationTestsDetected = fileExists('test/integration') || fileExists('tests/integration') ||
                                sh(script: "grep -q '\"test:integration\"' package.json 2>/dev/null && echo 'yes'", returnStdout: true).trim()
                            break
                        case 'go':
                            integrationTestsDetected = sh(script: "grep -rl '//go:build integration' . --include='*_test.go' 2>/dev/null | head -1", returnStdout: true).trim()
                            break
                        default:
                            integrationTestsDetected = fileExists('tests/integration') || fileExists('test/integration')
                    }

                    if (!integrationTestsDetected) {
                        echo """
╔══════════════════════════════════════════════════════════════╗
║  ⚠  NO INTEGRATION TESTS DETECTED                           ║
╠══════════════════════════════════════════════════════════════╣
║  Language: ${env.DETECTED_LANG}
║  No integration test directory or files found.               ║
║  Please write integration test cases to enable               ║
║  automated integration testing in the pipeline.              ║
╚══════════════════════════════════════════════════════════════╝
                        """
                        return
                    }

                    switch (env.DETECTED_LANG) {
                        case 'python':
                            sh '''
                                python3 -m pytest tests/integration/ \
                                    --junitxml="${REPORTS_DIR}/pytest-integration-results.xml" \
                                    -v -m "integration" 2>/dev/null || \
                                python3 -m pytest -m "integration" \
                                    --junitxml="${REPORTS_DIR}/pytest-integration-results.xml" \
                                    -v 2>/dev/null || echo "No integration tests found"
                            '''
                            break
                        case 'java-maven':
                            sh 'mvn verify -DskipUTs=true -Dmaven.test.failure.ignore=true || echo "No integration tests"'
                            break
                        case ['nodejs', 'react', 'angular']:
                            sh '''
                                if grep -q '"test:integration"' package.json 2>/dev/null; then
                                    npm run test:integration
                                else echo "No integration test script found"; fi
                            '''
                            break
                        case 'go':
                            sh 'go test ./... -v -tags=integration -json > "${REPORTS_DIR}/go-integration.json" 2>&1 || echo "No integration tests"'
                            break
                    }
                }
            }
        }

        // =====================================================================
        // STAGE 7: CycloneDX SBOM Generation (ALL LANGUAGES)
        // =====================================================================
        stage('CycloneDX SBOM Generation') {
            when { expression { params.GENERATE_SBOM } }
            steps {
                script {
                    echo """
╔══════════════════════════════════════════════════════════════╗
║  CycloneDX SBOM Generation — ${env.DETECTED_LANG}
║  Scanning root folder for all dependency manifests           ║
╚══════════════════════════════════════════════════════════════╝
                    """

                    sh 'pip install cyclonedx-bom cyclonedx-py pip-audit 2>/dev/null || true'

                    switch (env.DETECTED_LANG) {
                        case 'python':
                            sh """
                                echo "=== CycloneDX SBOM — Python ==="
                                if [ -f "requirements.txt" ]; then
                                    cyclonedx-py requirements -i requirements.txt --output-format json \
                                        -o "${REPORTS_DIR}/sbom/sbom-python-requirements.json" 2>/dev/null || true
                                    cyclonedx-py requirements -i requirements.txt --output-format xml \
                                        -o "${REPORTS_DIR}/sbom/sbom-python-requirements.xml" 2>/dev/null || true
                                fi
                                cyclonedx-py environment --output-format json \
                                    -o "${REPORTS_DIR}/sbom/sbom-python-environment.json" 2>/dev/null || true
                                pip-audit --format=cyclonedx-json \
                                    --output="${REPORTS_DIR}/sbom/sbom-python-pip-audit.json" 2>/dev/null || true
                                if [ -f "poetry.lock" ]; then
                                    cyclonedx-py poetry --output-format json \
                                        -o "${REPORTS_DIR}/sbom/sbom-python-poetry.json" 2>/dev/null || true
                                fi
                                if [ -f "Pipfile.lock" ]; then
                                    cyclonedx-py pipenv --output-format json \
                                        -o "${REPORTS_DIR}/sbom/sbom-python-pipenv.json" 2>/dev/null || true
                                fi
                            """
                            break
                        case 'java-maven':
                            sh """
                                echo "=== CycloneDX SBOM — Java (Maven) ==="
                                mvn org.cyclonedx:cyclonedx-maven-plugin:2.7.11:makeAggregateBom \
                                    -DoutputFormat=json -DoutputName=sbom-java-maven \
                                    -DoutputDirectory="${REPORTS_DIR}/sbom" \
                                    -DincludeLicenseText=true -DincludeCompileScope=true \
                                    -DincludeRuntimeScope=true -DincludeTestScope=false \
                                    -q 2>/dev/null || echo "Maven CycloneDX plugin failed"
                                mvn org.cyclonedx:cyclonedx-maven-plugin:2.7.11:makeAggregateBom \
                                    -DoutputFormat=xml -DoutputName=sbom-java-maven \
                                    -DoutputDirectory="${REPORTS_DIR}/sbom" -q 2>/dev/null || true
                            """
                            break
                        case 'java-gradle':
                            sh """
                                echo "=== CycloneDX SBOM — Java (Gradle) ==="
                                if grep -q 'cyclonedx' build.gradle 2>/dev/null || grep -q 'cyclonedx' build.gradle.kts 2>/dev/null; then
                                    ./gradlew cyclonedxBom 2>/dev/null || gradle cyclonedxBom 2>/dev/null || true
                                    cp build/reports/bom.json "${REPORTS_DIR}/sbom/sbom-java-gradle.json" 2>/dev/null || true
                                else
                                    cat > /tmp/cyclonedx-init.gradle <<'INITEOF'
initscript {
    repositories { mavenCentral() }
    dependencies { classpath 'org.cyclonedx:cyclonedx-gradle-plugin:1.8.2' }
}
allprojects {
    apply plugin: org.cyclonedx.gradle.CycloneDxPlugin
    cyclonedxBom { includeConfigs = ["runtimeClasspath"]; outputFormat = "json" }
}
INITEOF
                                    ./gradlew cyclonedxBom --init-script /tmp/cyclonedx-init.gradle 2>/dev/null || true
                                    cp build/reports/bom.json "${REPORTS_DIR}/sbom/sbom-java-gradle.json" 2>/dev/null || true
                                fi
                            """
                            break
                        case ['nodejs', 'react', 'angular']:
                            sh """
                                echo "=== CycloneDX SBOM — ${env.DETECTED_LANG} ==="
                                npx @cyclonedx/cyclonedx-npm --output-format JSON \
                                    --output-file "${REPORTS_DIR}/sbom/sbom-${env.DETECTED_LANG}.json" \
                                    --ignore-npm-errors 2>/dev/null || true
                                npx @cyclonedx/cyclonedx-npm --output-format XML \
                                    --output-file "${REPORTS_DIR}/sbom/sbom-${env.DETECTED_LANG}.xml" \
                                    --ignore-npm-errors 2>/dev/null || true
                                if [ ! -f "${REPORTS_DIR}/sbom/sbom-${env.DETECTED_LANG}.json" ]; then
                                    npm sbom --sbom-format cyclonedx --omit dev \
                                        > "${REPORTS_DIR}/sbom/sbom-${env.DETECTED_LANG}.json" 2>/dev/null || true
                                fi
                                npm audit --json > "${REPORTS_DIR}/npm-audit.json" 2>/dev/null || true
                            """
                            break
                        case 'go':
                            sh """
                                echo "=== CycloneDX SBOM — Go ==="
                                if command -v cyclonedx-gomod &>/dev/null; then
                                    cyclonedx-gomod mod -json -output "${REPORTS_DIR}/sbom/sbom-go.json" 2>/dev/null || true
                                    cyclonedx-gomod mod -output "${REPORTS_DIR}/sbom/sbom-go.xml" 2>/dev/null || true
                                fi
                            """
                            break
                        case 'dotnet':
                            sh """
                                echo "=== CycloneDX SBOM — .NET ==="
                                CSPROJ=\$(find . -maxdepth 2 -name '*.csproj' | head -1)
                                if [ -n "\${CSPROJ}" ]; then
                                    dotnet CycloneDX "\${CSPROJ}" --json \
                                        --output "${REPORTS_DIR}/sbom" --filename "sbom-dotnet.json" 2>/dev/null || true
                                fi
                            """
                            break
                    }

                    // ── Scan for additional language manifests in subdirectories ──
                    sh """
                        echo "=== Scanning root for additional language manifests ==="
                        find . -maxdepth 3 -name "requirements.txt" ! -path "./.venv/*" ! -path "./venv/*" ! -path "./pipeline-reports/*" | while read req; do
                            DIR=\$(dirname "\$req")
                            SAFE=\$(echo "\$DIR" | sed 's|[/.]|-|g' | sed 's|^-*||')
                            [ -z "\$SAFE" ] && SAFE="root"
                            if [ ! -f "${REPORTS_DIR}/sbom/sbom-python-\${SAFE}.json" ] && [ "\$DIR" != "." ]; then
                                echo "  Found Python: \$req"
                                pip-audit --format=cyclonedx-json \
                                    --output="${REPORTS_DIR}/sbom/sbom-python-\${SAFE}-audit.json" \
                                    -r "\$req" 2>/dev/null || true
                            fi
                        done

                        find . -maxdepth 3 -name "package.json" ! -path "*/node_modules/*" ! -path "./pipeline-reports/*" | while read pkg; do
                            DIR=\$(dirname "\$pkg")
                            SAFE=\$(echo "\$DIR" | sed 's|[/.]|-|g' | sed 's|^-*||')
                            [ -z "\$SAFE" ] && SAFE="root"
                            if [ ! -f "${REPORTS_DIR}/sbom/sbom-nodejs-\${SAFE}.json" ] && [ "\$DIR" != "." ]; then
                                echo "  Found Node.js: \$pkg"
                                cd "\$DIR"
                                npx @cyclonedx/cyclonedx-npm --output-format JSON \
                                    --output-file "${REPORTS_DIR}/sbom/sbom-nodejs-\${SAFE}.json" \
                                    --ignore-npm-errors 2>/dev/null || true
                                cd "${WORKSPACE}"
                            fi
                        done

                        echo "=== Trivy CycloneDX SBOM (full root scan) ==="
                        trivy fs --format cyclonedx \
                            --output "${REPORTS_DIR}/sbom/sbom-trivy-cyclonedx.json" \
                            "${WORKSPACE}" 2>/dev/null || true
                        trivy fs --format spdx-json \
                            --output "${REPORTS_DIR}/sbom/sbom-trivy-spdx.json" \
                            "${WORKSPACE}" 2>/dev/null || true
                    """

                    // ── Print SBOM summary ──
                    sh '''
                        python3 <<'PYEOF'
import json, os, glob
sbom_dir = os.path.join(os.environ.get("REPORTS_DIR", "."), "sbom")
total = 0
for sf in sorted(glob.glob(os.path.join(sbom_dir, "sbom-*.json"))):
    try:
        with open(sf) as f:
            data = json.load(f)
        n = len(data.get("components", []))
        total += n
        print(f"  {os.path.basename(sf):50s}  {n} components")
    except Exception as e:
        print(f"  {os.path.basename(sf):50s}  ERROR: {e}")
print(f"\n  TOTAL SBOM COMPONENTS: {total}")
PYEOF
                    '''
                }
            }
        }

        // =====================================================================
        // STAGE 8: SonarQube Analysis
        // =====================================================================
        stage('SonarQube Analysis') {
            when { expression { params.RUN_SONARQUBE } }
            steps {
                script {
                    def projectKey = params.SONAR_PROJECT_KEY ?: env.JOB_NAME ?: 'default-project'

                    echo """
╔══════════════════════════════════════════════════════════════╗
║  SonarQube Analysis — ${projectKey}
╚══════════════════════════════════════════════════════════════╝
                    """

                    def hasSonarScanner = sh(script: 'command -v sonar-scanner', returnStatus: true) == 0
                    def hasSonarToken = false
                    try { hasSonarToken = env.SONAR_TOKEN?.trim() ? true : false } catch (Exception e) { }

                    if (hasSonarScanner && hasSonarToken) {
                        def langParams = ''
                        switch (env.DETECTED_LANG) {
                            case 'python':
                                langParams = "-Dsonar.language=py -Dsonar.python.coverage.reportPaths=\"${REPORTS_DIR}/coverage.xml\" -Dsonar.python.xunit.reportPath=\"${REPORTS_DIR}/pytest-unit-results.xml\""
                                break
                            case 'java-maven':
                                langParams = "-Dsonar.java.binaries=\"target/classes\" -Dsonar.coverage.jacoco.xmlReportPaths=\"${REPORTS_DIR}/jacoco-coverage.xml\""
                                break
                            case 'java-gradle':
                                langParams = "-Dsonar.java.binaries=\"build/classes\" -Dsonar.coverage.jacoco.xmlReportPaths=\"${REPORTS_DIR}/jacoco-coverage.xml\""
                                break
                            case ['nodejs', 'react', 'angular']:
                                langParams = "-Dsonar.javascript.lcov.reportPaths=\"${REPORTS_DIR}/lcov.info\""
                                break
                            case 'go':
                                langParams = "-Dsonar.go.coverage.reportPaths=\"${REPORTS_DIR}/go-coverage.out\""
                                break
                        }

                        sh """
                            sonar-scanner \
                                -Dsonar.host.url="\${SONAR_HOST_URL}" \
                                -Dsonar.login="\${SONAR_TOKEN}" \
                                -Dsonar.projectKey="${projectKey}" \
                                -Dsonar.projectName="${projectKey}" \
                                -Dsonar.sources=. \
                                -Dsonar.exclusions="**/node_modules/**,**/.trivy-cache/**,**/pipeline-reports/**" \
                                -Dsonar.qualitygate.wait=true \
                                ${langParams} \
                                2>&1 | tee "${REPORTS_DIR}/sonarqube/sonar-scanner-output.txt" || true

                            sleep 10
                            curl -s -u "\${SONAR_TOKEN}:" \
                                "\${SONAR_HOST_URL}/api/qualitygates/project_status?projectKey=${projectKey}" \
                                > "${REPORTS_DIR}/sonarqube/quality-gate-status.json" 2>/dev/null || true
                            curl -s -u "\${SONAR_TOKEN}:" \
                                "\${SONAR_HOST_URL}/api/measures/component?component=${projectKey}&metricKeys=bugs,vulnerabilities,code_smells,coverage,duplicated_lines_density,ncloc,security_hotspots" \
                                > "${REPORTS_DIR}/sonarqube/project-measures.json" 2>/dev/null || true
                            curl -s -u "\${SONAR_TOKEN}:" \
                                "\${SONAR_HOST_URL}/api/issues/search?componentKeys=${projectKey}&severities=BLOCKER,CRITICAL&statuses=OPEN,CONFIRMED&ps=500" \
                                > "${REPORTS_DIR}/sonarqube/critical-issues.json" 2>/dev/null || true
                        """
                    } else {
                        echo "SonarQube not available — generating local quality report"
                        sh '''
                            python3 <<'PYEOF'
import json, os, re
reports_dir = os.environ.get("REPORTS_DIR", ".")
report = {"sonarqube_available": False, "local_analysis": True, "quality_metrics": {}}
for name, file in [("bandit","bandit-report.json"),("flake8","flake8-report.txt"),("pylint","pylint-report.txt"),("eslint","eslint-report.json")]:
    fpath = os.path.join(reports_dir, file)
    if os.path.exists(fpath):
        if name == "bandit":
            with open(fpath) as f: data = json.load(f)
            results = data.get("results", [])
            report["quality_metrics"]["bandit_total"] = len(results)
            report["quality_metrics"]["bandit_high"] = sum(1 for r in results if r.get("issue_severity") == "HIGH")
        elif name == "flake8":
            with open(fpath) as f: report["quality_metrics"]["flake8_issues"] = len(f.readlines())
        elif name == "pylint":
            with open(fpath) as f: content = f.read()
            m = re.search(r"Your code has been rated at ([0-9.]+)", content)
            if m: report["quality_metrics"]["pylint_score"] = float(m.group(1))
        elif name == "eslint":
            with open(fpath) as f: data = json.load(f)
            report["quality_metrics"]["eslint_errors"] = sum(r.get("errorCount",0) for r in data)
cov_file = os.path.join(reports_dir, "coverage.xml")
if os.path.exists(cov_file):
    import xml.etree.ElementTree as ET
    tree = ET.parse(cov_file)
    root = tree.getroot()
    report["quality_metrics"]["coverage_percent"] = round(float(root.attrib.get("line-rate",0))*100, 1)
os.makedirs(os.path.join(reports_dir, "sonarqube"), exist_ok=True)
with open(os.path.join(reports_dir, "sonarqube", "local-quality-report.json"), "w") as f:
    json.dump(report, f, indent=2)
for k,v in report["quality_metrics"].items(): print(f"    {k}: {v}")
PYEOF
                        '''
                    }
                }
            }
        }

        // =====================================================================
        // STAGE 9: Build Application
        // =====================================================================
        stage('Build Application') {
            steps {
                script {
                    if (env.HAS_MAKEFILE == 'true') {
                        sh 'make build 2>/dev/null || make all 2>/dev/null || make 2>/dev/null || echo "make completed"'
                    } else {
                        switch (env.DETECTED_LANG) {
                            case 'python':
                                sh '''
                                    if [ -f "setup.py" ]; then python3 setup.py bdist_wheel 2>/dev/null || true
                                    elif [ -f "pyproject.toml" ]; then pip install build && python3 -m build 2>/dev/null || true
                                    else echo "No build step needed"; fi
                                '''
                                break
                            case 'java-maven': sh 'mvn package -DskipTests -q'; break
                            case 'java-gradle': sh './gradlew build -x test 2>/dev/null || gradle build -x test'; break
                            case ['nodejs', 'react', 'angular']:
                                sh 'if grep -q \'"build"\' package.json 2>/dev/null; then npm run build; else echo "No build script"; fi'
                                break
                            case 'go': sh 'CGO_ENABLED=0 go build -o "${REPORTS_DIR}/app-binary" ./... 2>/dev/null || go build ./...'; break
                            case 'dotnet': sh 'dotnet build --configuration Release'; break
                        }
                    }
                }
            }
        }

        // =====================================================================
        // STAGE 10: Docker Build & Push
        // =====================================================================
        stage('Docker Build & Push') {
            when { expression { (env.HAS_DOCKERFILE == 'true') || (params.IMAGE_NAME?.trim()) } }
            steps {
                script {
                    def fullImage = "${REGISTRY}/${params.IMAGE_NAME ?: 'app'}:${params.IMAGE_TAG}"
                    def dfPath = params.DOCKERFILE_PATH ?: 'Dockerfile'
                    if (!fileExists(dfPath) && fileExists('Containerfile')) { dfPath = 'Containerfile' }
                    sh """
                        if command -v podman &>/dev/null; then
                            podman build -t "${fullImage}" -f "${dfPath}" .
                            podman push "${fullImage}" --tls-verify=false
                        elif command -v docker &>/dev/null; then
                            docker build -t "${fullImage}" -f "${dfPath}" .
                            docker push "${fullImage}"
                        fi
                    """
                    env.BUILT_IMAGE = fullImage
                }
            }
        }

        // =====================================================================
        // STAGE 11: Trivy Image Scan
        // =====================================================================
        stage('Trivy Image Scan') {
            when { expression { params.RUN_TRIVY_SCAN && env.BUILT_IMAGE?.trim() } }
            steps {
                sh """
                    trivy image --podman-host "" --severity "\${SCAN_SEVERITY}" \
                        --format json --output "${REPORTS_DIR}/trivy-image-scan.json" \
                        "${env.BUILT_IMAGE}" || true
                    trivy image --podman-host "" --severity "\${SCAN_SEVERITY}" \
                        --format table "${env.BUILT_IMAGE}" | tee "${REPORTS_DIR}/trivy-image-scan.txt" || true
                """
            }
        }

        // =====================================================================
        // STAGE 12: SAST & Secret Detection
        // =====================================================================
        stage('SAST & Secret Detection') {
            when { expression { params.RUN_TRIVY_SCAN || params.RUN_SECRET_DETECTION } }
            parallel {
                stage('Trivy FS Scan') {
                    when { expression { params.RUN_TRIVY_SCAN } }
                    steps {
                        sh '''
                            trivy fs --scanners vuln,misconfig --severity "${SCAN_SEVERITY}" \
                                --format json --output "${REPORTS_DIR}/trivy-fs-scan.json" "${WORKSPACE}" || true
                            trivy fs --scanners vuln,misconfig --severity "${SCAN_SEVERITY}" \
                                --format table "${WORKSPACE}" | tee "${REPORTS_DIR}/trivy-fs-scan.txt" || true
                        '''
                    }
                }
                stage('Secret Detection') {
                    when { expression { params.RUN_SECRET_DETECTION } }
                    steps {
                        sh '''
                            trivy fs --scanners secret --format json \
                                --output "${REPORTS_DIR}/secret-scan.json" "${WORKSPACE}" || true
                            trivy fs --scanners secret --format table \
                                "${WORKSPACE}" | tee "${REPORTS_DIR}/secret-scan.txt" || true
                        '''
                    }
                }
            }
        }

        // =====================================================================
        // STAGE 13: SCA — Dependency Vulnerability Scan
        // =====================================================================
        stage('SCA — Dependency Scan') {
            when { expression { params.RUN_TRIVY_SCAN } }
            parallel {
                stage('Trivy SCA') {
                    steps {
                        sh '''
                            trivy fs --scanners vuln,license --severity "${SCAN_SEVERITY}" \
                                --format json --output "${REPORTS_DIR}/trivy-sca.json" "${WORKSPACE}" || true
                            trivy fs --scanners vuln,license --severity "${SCAN_SEVERITY}" \
                                --format table "${WORKSPACE}" | tee "${REPORTS_DIR}/trivy-sca.txt" || true
                        '''
                    }
                }
                stage('OWASP Dependency-Check') {
                    when { expression { params.RUN_OWASP_CHECK && fileExists('/opt/dependency-check/bin/dependency-check.sh') } }
                    steps {
                        sh '''
                            /opt/dependency-check/bin/dependency-check.sh \
                                --project "${JOB_NAME}" --scan "${WORKSPACE}" \
                                --format HTML --format JSON --out "${REPORTS_DIR}" \
                                --failOnCVSS 7 --enableExperimental || true
                        '''
                    }
                }
                stage('Grype Scan') {
                    when { expression { params.RUN_GRYPE && sh(script: 'command -v grype', returnStatus: true) == 0 } }
                    steps {
                        sh '''
                            grype dir:"${WORKSPACE}" --output json --file "${REPORTS_DIR}/grype-sca.json" || true
                            grype dir:"${WORKSPACE}" --output table | tee "${REPORTS_DIR}/grype-sca.txt" || true
                        '''
                    }
                }
            }
        }

        // =====================================================================
        // STAGE 14: Dockerfile Lint
        // =====================================================================
        stage('Dockerfile Lint') {
            when { expression { params.RUN_DOCKERFILE_LINT && (env.HAS_DOCKERFILE == 'true') } }
            steps {
                sh '''
                    DFILE="Dockerfile"; [ -f "Containerfile" ] && DFILE="Containerfile"
                    if command -v hadolint &>/dev/null; then
                        hadolint --format json "$DFILE" > "${REPORTS_DIR}/hadolint.json" 2>/dev/null || true
                        hadolint "$DFILE" | tee "${REPORTS_DIR}/hadolint.txt" || true
                    else
                        trivy config --severity "${SCAN_SEVERITY}" --format table "$DFILE" || true
                    fi
                '''
            }
        }

        // =====================================================================
        // STAGE 15: ShellCheck
        // =====================================================================
        stage('ShellCheck') {
            when { expression { return sh(script: 'find "${WORKSPACE}" -name "*.sh" -not -path "*/.trivy-cache/*" -not -path "*/pipeline-reports/*" | head -1', returnStdout: true).trim() } }
            steps {
                sh '''
                    if command -v shellcheck &>/dev/null; then
                        find "${WORKSPACE}" -name "*.sh" -type f ! -path "*/node_modules/*" ! -path "*/.trivy-cache/*" ! -path "*/pipeline-reports/*" \
                            -exec shellcheck --format=json {} + > "${REPORTS_DIR}/shellcheck.json" 2>/dev/null || true
                    fi
                '''
            }
        }

        // =====================================================================
        // STAGE 16: K8s Manifest Security Scan
        // =====================================================================
        stage('K8s Manifest Security Scan') {
            when { expression { params.RUN_K8S_MANIFEST_SCAN && env.HAS_K8S_MANIFESTS == 'true' } }
            parallel {
                stage('Trivy K8s Config') {
                    steps {
                        sh '''
                            MANIFESTS_DIR="${WORKSPACE}/${K8S_MANIFESTS_DIR:-cat-deployments}"
                            trivy config --severity "${SCAN_SEVERITY}" --format json \
                                --output "${REPORTS_DIR}/trivy-k8s-config.json" "${MANIFESTS_DIR}" || true
                            trivy config --severity "${SCAN_SEVERITY}" --format table \
                                "${MANIFESTS_DIR}" | tee "${REPORTS_DIR}/trivy-k8s-config.txt" || true
                        '''
                    }
                }
                stage('Kubesec Scan') {
                    when { expression { return sh(script: 'command -v kubesec', returnStatus: true) == 0 } }
                    steps {
                        sh '''
                            MANIFESTS_DIR="${WORKSPACE}/${K8S_MANIFESTS_DIR:-cat-deployments}"
                            > "${REPORTS_DIR}/kubesec-results.json"
                            find "${MANIFESTS_DIR}" \\( -name "*deployment*" -o -name "*pod*" \\) \\( -name "*.yml" -o -name "*.yaml" \\) \
                                | while read f; do kubesec scan "$f" >> "${REPORTS_DIR}/kubesec-results.json" 2>/dev/null || true; done
                        '''
                    }
                }
            }
        }

        // =====================================================================
        // STAGE 17: Security Gate
        // =====================================================================
        stage('Security Gate') {
            steps {
                script {
                    def gateResult = sh(script: '''
                        CRITICAL_COUNT=0; HIGH_COUNT=0; SECRETS_COUNT=0; MISCONFIG_COUNT=0
                        for REPORT in "${REPORTS_DIR}"/trivy-*.json; do
                            [ -f "${REPORT}" ] || continue
                            COUNTS=$(python3 -c "
import json
with open('${REPORT}') as f: data = json.load(f)
results = data.get('Results', [])
crit = sum(1 for r in results for v in r.get('Vulnerabilities', []) if v.get('Severity') == 'CRITICAL')
high = sum(1 for r in results for v in r.get('Vulnerabilities', []) if v.get('Severity') == 'HIGH')
misc = sum(1 for r in results for m in r.get('Misconfigurations', []) if m.get('Severity') in ('CRITICAL','HIGH'))
print(f'{crit} {high} {misc}')
" 2>/dev/null || echo "0 0 0")
                            C=$(echo "$COUNTS" | awk '{print $1}'); H=$(echo "$COUNTS" | awk '{print $2}'); M=$(echo "$COUNTS" | awk '{print $3}')
                            CRITICAL_COUNT=$((CRITICAL_COUNT+C)); HIGH_COUNT=$((HIGH_COUNT+H)); MISCONFIG_COUNT=$((MISCONFIG_COUNT+M))
                        done
                        if [ -f "${REPORTS_DIR}/secret-scan.json" ]; then
                            SECRETS_COUNT=$(python3 -c "
import json
with open('${REPORTS_DIR}/secret-scan.json') as f: data = json.load(f)
print(sum(len(r.get('Secrets',[])) for r in data.get('Results',[])))
" 2>/dev/null || echo "0")
                        fi
                        cat > "${REPORTS_DIR}/gate-results.txt" <<EOF
CRITICAL_VULNS=${CRITICAL_COUNT}
HIGH_VULNS=${HIGH_COUNT}
SECRETS=${SECRETS_COUNT}
MISCONFIGS=${MISCONFIG_COUNT}
EOF
                        echo "╔══════════════════════════════════════════════════════════════╗"
                        echo "║              SECURITY GATE RESULTS                           ║"
                        echo "╠══════════════════════════════════════════════════════════════╣"
                        printf "║  CRITICAL:  %-48s║\\n" "${CRITICAL_COUNT}"
                        printf "║  HIGH:      %-48s║\\n" "${HIGH_COUNT}"
                        printf "║  Secrets:   %-48s║\\n" "${SECRETS_COUNT}"
                        printf "║  Misconfig: %-48s║\\n" "${MISCONFIG_COUNT}"
                        echo "╠══════════════════════════════════════════════════════════════╣"
                        if [ "${CRITICAL_COUNT}" -gt 0 ] || [ "${SECRETS_COUNT}" -gt 0 ]; then
                            echo "║  GATE: FAIL                                                  ║"
                            echo "╚══════════════════════════════════════════════════════════════╝"
                            exit 1
                        else
                            echo "║  GATE: PASS                                                  ║"
                            echo "╚══════════════════════════════════════════════════════════════╝"
                            exit 0
                        fi
                    ''', returnStatus: true)

                    if (gateResult != 0 && params.FAIL_ON_CRITICAL) {
                        unstable('CRITICAL vulnerabilities or secrets detected — marking UNSTABLE')
                    }
                }
            }
        }

        // =====================================================================
        // STAGE 18: Deploy to K8s (optional)
        // =====================================================================
        stage('Deploy to K8s') {
            when { expression { params.DEPLOY_TO_K8S && env.BUILT_IMAGE?.trim() } }
            steps {
                script {
                    def namespace = params.K8S_NAMESPACE ?: params.IMAGE_NAME
                    sh """
                        kubectl set image deployment/${params.IMAGE_NAME} \
                            ${params.IMAGE_NAME}=${env.BUILT_IMAGE} -n ${namespace} 2>/dev/null || true
                        kubectl rollout status deployment/${params.IMAGE_NAME} \
                            -n ${namespace} --timeout=300s 2>/dev/null || true
                    """
                }
            }
        }

        // =====================================================================
        // STAGE 19: Comprehensive Final Report
        // =====================================================================
        stage('Comprehensive Final Report') {
            steps {
                script {
                    echo """
╔══════════════════════════════════════════════════════════════╗
║     Generating Comprehensive Final Report                    ║
║     ├── [1] Unit Test Report                                 ║
║     ├── [2] Coverage Report                                  ║
║     ├── [3] SonarQube Report                                 ║
║     ├── [4] CycloneDX SBOM Report                            ║
║     ├── [5] Trivy Security Report                            ║
║     ├── [6] Secret Detection Report                          ║
║     ├── [7] Additional Reports                               ║
║     └── [FINAL] Comprehensive HTML + TXT + JSON              ║
║         ├── HIGH / CRITICAL / BLOCKER issues                ║
║         ├── Test Coverage overview                           ║
║         └── SonarQube overview                               ║
╚══════════════════════════════════════════════════════════════╝
                    """
                }

                sh """
                    export REPORTS_DIR="${REPORTS_DIR}"
                    export LANGUAGE="${env.DETECTED_LANG}"
                    export IMAGE_NAME="${env.BUILT_IMAGE ?: params.IMAGE_NAME ?: 'N/A'}"
                    export COVERAGE_THRESHOLD="${COVERAGE_THRESHOLD}"

                    chmod +x "${WORKSPACE}/jenkins/scripts/generate-comprehensive-report.sh" 2>/dev/null || true
                    bash "${WORKSPACE}/jenkins/scripts/generate-comprehensive-report.sh" \
                        "${REPORTS_DIR}" "${env.DETECTED_LANG}" \
                        "${env.BUILT_IMAGE ?: params.IMAGE_NAME ?: 'N/A'}"
                """

                sh '''
                    if [ -f "${REPORTS_DIR}/comprehensive-report.txt" ]; then
                        echo ""; echo ""
                        cat "${REPORTS_DIR}/comprehensive-report.txt"
                    fi

                    echo ""
                    echo "╔══════════════════════════════════════════════════════════════════════════════╗"
                    echo "║  REPORT FILES GENERATED                                                     ║"
                    echo "╠══════════════════════════════════════════════════════════════════════════════╣"
                    echo "║  [COMPREHENSIVE]"
                    for f in comprehensive-report.html comprehensive-report.txt comprehensive-report.json; do
                        [ -f "${REPORTS_DIR}/$f" ] && printf "║    %-70s ║\\n" "$f"
                    done
                    echo "║  [UNIT TESTS]"
                    for f in "${REPORTS_DIR}"/pytest-*.xml "${REPORTS_DIR}"/pytest-*.html; do
                        [ -f "$f" ] && printf "║    %-70s ║\\n" "$(basename $f)"; done
                    echo "║  [COVERAGE]"
                    for f in coverage.xml jacoco-coverage.xml go-coverage.out lcov.info; do
                        [ -f "${REPORTS_DIR}/$f" ] && printf "║    %-70s ║\\n" "$f"; done
                    echo "║  [SONARQUBE]"
                    for f in "${REPORTS_DIR}"/sonarqube/*; do
                        [ -f "$f" ] && printf "║    %-70s ║\\n" "sonarqube/$(basename $f)"; done
                    echo "║  [SBOM]"
                    for f in "${REPORTS_DIR}"/sbom/*; do
                        [ -f "$f" ] && printf "║    %-70s ║\\n" "sbom/$(basename $f)"; done
                    echo "║  [TRIVY]"
                    for f in "${REPORTS_DIR}"/trivy-*.json; do
                        [ -f "$f" ] && printf "║    %-70s ║\\n" "$(basename $f)"; done
                    echo "║  [SECRET DETECTION]"
                    [ -f "${REPORTS_DIR}/secret-scan.json" ] && printf "║    %-70s ║\\n" "secret-scan.json"
                    echo "║  [OTHER]"
                    for f in hadolint.json shellcheck.json grype-sca.json bandit-report.json npm-audit.json gate-results.txt; do
                        [ -f "${REPORTS_DIR}/$f" ] && printf "║    %-70s ║\\n" "$f"; done
                    echo "╚══════════════════════════════════════════════════════════════════════════════╝"
                '''
            }
        }
    }

    // =========================================================================
    // Post Actions
    // =========================================================================
    post {
        always {
            archiveArtifacts artifacts: 'pipeline-reports/**/*', allowEmptyArchive: true

            publishHTML(target: [
                allowMissing: true,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: 'pipeline-reports',
                reportFiles: 'comprehensive-report.html,pytest-report.html',
                reportName: 'Comprehensive DevSecOps Report'
            ])

            junit allowEmptyResults: true, testResults: 'pipeline-reports/**/*.xml'

            echo """
╔══════════════════════════════════════════════════════════════╗
║  Pipeline Complete — View Reports:                           ║
║    • HTML Report: pipeline-reports/comprehensive-report.html ║
║    • Jenkins: Build → Comprehensive DevSecOps Report         ║
╚══════════════════════════════════════════════════════════════╝
            """
        }
        success { echo 'Comprehensive DevSecOps Pipeline PASSED' }
        unstable { echo 'Pipeline completed with WARNINGS — review the Comprehensive Report' }
        failure { echo 'Pipeline FAILED — review Comprehensive Report for details' }
        cleanup {
            cleanWs(deleteDirs: true, patterns: [
                [pattern: '.trivy-cache/**', type: 'INCLUDE'],
                [pattern: 'node_modules/**', type: 'INCLUDE']
            ])
        }
    }
}

// =============================================================================
// Helper: Auto-detect project language
// =============================================================================
def detectLanguage() {
    if (fileExists('requirements.txt') || fileExists('setup.py') || fileExists('pyproject.toml') || fileExists('Pipfile')) {
        echo "Detected: Python"; return 'python'
    }
    if (fileExists('pom.xml')) { echo "Detected: Java (Maven)"; return 'java-maven' }
    if (fileExists('build.gradle') || fileExists('build.gradle.kts')) { echo "Detected: Java (Gradle)"; return 'java-gradle' }
    if (fileExists('angular.json')) { echo "Detected: Angular"; return 'angular' }
    if (fileExists('package.json')) {
        def pkgJson = readFile('package.json')
        if (pkgJson.contains('"react"')) { echo "Detected: React"; return 'react' }
        echo "Detected: Node.js"; return 'nodejs'
    }
    if (fileExists('go.mod')) { echo "Detected: Go"; return 'go' }
    if (sh(script: 'find . -maxdepth 2 -name "*.csproj" | head -1', returnStdout: true).trim()) { echo "Detected: .NET"; return 'dotnet' }
    echo "Could not auto-detect — defaulting to python"
    return 'python'
}
