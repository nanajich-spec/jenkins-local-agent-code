                stage('OWASP Dependency-Check') {
                    when { expression { params.RUN_OWASP_CHECK && fileExists('/opt/dependency-check/bin/dependency-check.sh') } }
                    steps {
                        sh """
                            /opt/dependency-check/bin/dependency-check.sh \
                                --project '${env.JOB_NAME ?: 'project'}' \
                                --scan '${WORKSPACE}' \
                                --format HTML --format JSON \
                                --out '${REPORTS_DIR}' \
                                --failOnCVSS 7 \
                                --enableExperimental 2>/dev/null || true
                        """
                    }
                }
            }
        }

        // =====================================================================
        // STAGE 13: Dockerfile Lint (Hadolint)
        // =====================================================================
        stage('Dockerfile Lint') {
            when { expression { params.RUN_DOCKERFILE_LINT } }
            steps {
                script {
                    if (env.HAS_DOCKERFILE == 'false') {
                        sh """
echo "======================================================================"
echo "  [WARNING] No Dockerfile found — Hadolint scan SKIPPED"
echo "======================================================================"
echo "  Add a Dockerfile or Containerfile to enable Dockerfile lint."
echo "======================================================================"
echo 'No Dockerfile found — Hadolint skipped' >> '${REPORTS_DIR}/pipeline-warnings.txt'
"""
                        return
                    }
                    sh """
export REPORTS_DIR='${REPORTS_DIR}'
export WORKSPACE='${WORKSPACE}'
python3 <<'HADOLINT_EOF'
import json, subprocess, os

WORKSPACE   = os.environ['WORKSPACE']
REPORTS_DIR = os.environ['REPORTS_DIR']
modules     = json.loads(open(os.path.join(REPORTS_DIR, 'modules.json')).read())

# Collect all Dockerfiles from all modules (deduped, in order)
seen = set()
all_dfs = []
for m in modules.values():
    for df in m.get('dockerfiles', []):
        if df not in seen:
            seen.add(df)
            all_dfs.append(df)

if not all_dfs:
    print('  [INFO] No Dockerfiles found in any module — hadolint skipped')
    exit(0)

print(f'  Linting {len(all_dfs)} Dockerfile(s): {all_dfs}')
hadolint_txt = os.path.join(REPORTS_DIR, 'hadolint.txt')
open(hadolint_txt, 'w').close()

for df in all_dfs:
    df_abs = os.path.join(WORKSPACE, df)
    if not os.path.isfile(df_abs):
        print(f'  [WARN] Not found: {df_abs}')
        continue
    safe = df.replace('/', '-').lstrip('-')
    print(f'\\n  --- {df} ---')
    with open(hadolint_txt, 'a') as out:
        out.write(f'\\n--- {df} ---\\n')

    if subprocess.run('command -v hadolint', shell=True, stdout=subprocess.DEVNULL,
                      stderr=subprocess.DEVNULL).returncode == 0:
        subprocess.run(f'hadolint "{df_abs}" 2>&1 | tee -a "{hadolint_txt}"', shell=True)
        subprocess.run(
            f'hadolint --format json "{df_abs}" > "{REPORTS_DIR}/hadolint-{safe}.json" 2>/dev/null',
            shell=True)
    else:
        print('  [WARN] hadolint not found — using trivy config scan')
        subprocess.run(
            f'trivy config --severity CRITICAL,HIGH --format table "{df_abs}" '
            f'2>/dev/null | tee -a "{hadolint_txt}"', shell=True)
        subprocess.run(
            f'trivy config --severity CRITICAL,HIGH --format json '
            f'--output "{REPORTS_DIR}/trivy-dockerfile-{safe}.json" "{df_abs}" 2>/dev/null',
            shell=True)

print(f'\\n  === Hadolint summary ({len(all_dfs)} file(s) linted) ===')
HADOLINT_EOF
"""
                }
            }
        }

        // =====================================================================
        // STAGE 14: ShellCheck
        // =====================================================================
        stage('ShellCheck') {
            steps {
                script {
                    def hasShScripts = sh(script: """
                        find '${WORKSPACE}' -name '*.sh' \
                            ! -path '*/.trivy-cache/*' \
                            ! -path '*/pipeline-reports/*' \
                            ! -path '*/node_modules/*' | head -1
                    """, returnStdout: true).trim()

                    if (!hasShScripts) {
                        echo "[INFO] No shell scripts found — ShellCheck skipped"
                        return
                    }
                    sh """
                        command -v shellcheck &>/dev/null || { echo "[WARN] shellcheck not on agent"; return 0; }
                        find '${WORKSPACE}' -name '*.sh' -type f \
                            ! -path '*/node_modules/*' \
                            ! -path '*/.trivy-cache/*' \
                            ! -path '*/pipeline-reports/*' \
                            -exec shellcheck --format=json {} + \
                            > '${REPORTS_DIR}/shellcheck.json' 2>/dev/null || true
                        echo "[OK] ShellCheck complete"
                    """
                }
            }
        }

        // =====================================================================
        // STAGE 15: K8s Manifest Security Scan
        // =====================================================================
        stage('K8s Manifest Security Scan') {
            when { expression { params.RUN_K8S_MANIFEST_SCAN } }
            steps {
                script {
                    if (env.HAS_K8S_MANIFESTS == 'false') {
                        sh """
echo "======================================================================"
echo "  [WARNING] No Kubernetes manifests found in '${env.K8S_MANIFESTS_DIR}/' — scan SKIPPED"
echo "======================================================================"
echo "  Place .yaml/.yml Kubernetes manifests in ${env.K8S_MANIFESTS_DIR}/"
echo "  to enable manifest security scanning."
echo "======================================================================"
echo 'No K8s manifests in ${env.K8S_MANIFESTS_DIR}/ — scan skipped' >> '${REPORTS_DIR}/pipeline-warnings.txt'
"""
                        return
                    }

                    def k8sDir = "${WORKSPACE}/${env.K8S_MANIFESTS_DIR}"
                    sh """
                        echo "=== Trivy K8s Config Scan: ${k8sDir} ==="
                        trivy config \
                            --severity '${SCAN_SEVERITY}' \
                            --format json \
                            --output '${REPORTS_DIR}/trivy/trivy-k8s-config.json' \
                            '${k8sDir}' 2>/dev/null || \
                        echo '{"Results":[]}' > '${REPORTS_DIR}/trivy/trivy-k8s-config.json'

                        trivy config \
                            --severity '${SCAN_SEVERITY}' \
                            --format table \
                            '${k8sDir}' 2>/dev/null | tee '${REPORTS_DIR}/trivy/trivy-k8s-config.txt' || true

                        if command -v kubesec &>/dev/null; then
                            echo "=== Kubesec Risk Analysis ==="
                            > '${REPORTS_DIR}/kubesec-results.json'
                            find '${k8sDir}' \\( -name '*deployment*' -o -name '*pod*' \\) \
                                \\( -name '*.yml' -o -name '*.yaml' \\) | while read mf; do
                                echo "  Scanning: \$mf"
                                kubesec scan "\$mf" >> '${REPORTS_DIR}/kubesec-results.json' 2>/dev/null || true
                            done
                        else
                            echo "[WARN] kubesec not available — kubesec scan skipped"
                        fi
                    """
                }
            }
        }

        // =====================================================================
        // STAGE 16: Security Gate
        // =====================================================================
        stage('Security Gate') {
            steps {
                script {
                    def gateStatus = sh(script: """#!/usr/bin/env bash
set -uo pipefail
CRITICAL=0; HIGH=0; SECRETS=0; MISCONFIG=0

for REPORT in "${REPORTS_DIR}/trivy/"*.json "${REPORTS_DIR}/trivy-image-scan.json"; do
    [ -f "\$REPORT" ] || continue
    COUNTS=\$(python3 -c "
import json, sys
try:
    with open(sys.argv[1]) as f: data = json.load(f)
    results = data.get('Results', [])
    c = sum(1 for r in results for v in (r.get('Vulnerabilities') or []) if v.get('Severity') == 'CRITICAL')
    h = sum(1 for r in results for v in (r.get('Vulnerabilities') or []) if v.get('Severity') == 'HIGH')
    m = sum(1 for r in results for v in (r.get('Misconfigurations') or []) if v.get('Severity') in ('CRITICAL','HIGH'))
    print(c, h, m)
except: print('0 0 0')
" "\$REPORT" 2>/dev/null || echo "0 0 0")
    CRITICAL=\$((CRITICAL + \$(echo "\$COUNTS" | awk '{print \$1}')))
    HIGH=\$((HIGH     + \$(echo "\$COUNTS" | awk '{print \$2}')))
    MISCONFIG=\$((MISCONFIG + \$(echo "\$COUNTS" | awk '{print \$3}')))
done

if [ -f "${REPORTS_DIR}/secret-scan.json" ]; then
    SECRETS=\$(python3 -c "
import json
try:
    with open('${REPORTS_DIR}/secret-scan.json') as f: data = json.load(f)
    print(sum(len(r.get('Secrets') or []) for r in data.get('Results', [])))
except: print(0)
" 2>/dev/null || echo 0)
fi

cat > "${REPORTS_DIR}/gate-results.txt" <<EOF
CRITICAL_VULNS=\${CRITICAL}
HIGH_VULNS=\${HIGH}
SECRETS=\${SECRETS}
MISCONFIGS=\${MISCONFIG}
EOF

echo "======================================================================"
echo "  SECURITY GATE RESULTS"
echo "======================================================================"
printf "  CRITICAL vulnerabilities:  %s\\n" "\${CRITICAL}"
printf "  HIGH vulnerabilities:      %s\\n" "\${HIGH}"
printf "  Secrets detected:          %s\\n" "\${SECRETS}"
printf "  Misconfigurations (C/H):   %s\\n" "\${MISCONFIG}"
echo "----------------------------------------------------------------------"
if [ "\${CRITICAL}" -gt 0 ] || [ "\${SECRETS}" -gt 0 ]; then
    echo "  GATE: FAIL — CRITICAL vulns or secrets found"
    echo "======================================================================"
    exit 1
else
    echo "  GATE: PASS"
    echo "======================================================================"
    exit 0
fi
""", returnStatus: true)

                    if (gateStatus != 0 && params.FAIL_ON_CRITICAL) {
                        unstable('CRITICAL vulnerabilities or secrets detected — build marked UNSTABLE')
                    }
                }
            }
        }

        // =====================================================================
        // STAGE 17: Deploy to K8s (optional)
        // =====================================================================
        stage('Deploy to K8s') {
            when { expression { params.DEPLOY_TO_K8S && (env.BUILT_IMAGE?.trim()) } }
            steps {
                script {
                    def ns      = params.K8S_NAMESPACE ?: params.IMAGE_NAME ?: 'default'
                    def imgName = params.IMAGE_NAME ?: 'app'
                    sh """
                        kubectl set image deployment/${imgName} \
                            ${imgName}=${env.BUILT_IMAGE} -n ${ns} 2>/dev/null || true
                        kubectl rollout status deployment/${imgName} \
                            -n ${ns} --timeout=300s 2>/dev/null || true
                    """
                }
            }
        }

        // =====================================================================
        // STAGE 18: Comprehensive Final Report
        // =====================================================================
        stage('Comprehensive Final Report') {
            steps {
                sh """
                    # Copy trivy sub-dir files to root for report generator backward compat
                    for f in '${REPORTS_DIR}/trivy/'*.json; do
                        [ -f "\$f" ] && cp "\$f" '${REPORTS_DIR}/' 2>/dev/null || true
                    done
                    true
                """

                sh """
                    export REPORTS_DIR='${REPORTS_DIR}'
                    export LANGUAGE='${env.DETECTED_LANG}'
                    export IMAGE_NAME='${env.BUILT_IMAGE ?: params.IMAGE_NAME ?: 'N/A'}'
                    export COVERAGE_THRESHOLD='${COVERAGE_THRESHOLD}'
                    export SCAN_ID='${params.SCAN_ID ?: ''}'

                    chmod +x '${WORKSPACE}/jenkins/scripts/generate-comprehensive-report.sh' 2>/dev/null || true
                    bash '${WORKSPACE}/jenkins/scripts/generate-comprehensive-report.sh' \
                        '${REPORTS_DIR}' '${env.DETECTED_LANG}' \
                        '${env.BUILT_IMAGE ?: params.IMAGE_NAME ?: 'N/A'}' 2>&1 || true
                """

                sh '''
                    echo ""; echo ""
                    [ -f "${REPORTS_DIR}/comprehensive-report.txt" ] && \
                        cat "${REPORTS_DIR}/comprehensive-report.txt" || true

                    echo ""
                    echo "======================================================================"
                    echo "  PIPELINE WARNINGS"
                    echo "======================================================================"
                    cat "${REPORTS_DIR}/pipeline-warnings.txt" 2>/dev/null || echo "  No warnings"
                    echo "======================================================================"

                    echo ""
                    echo "======================================================================"
                    echo "  GENERATED REPORT FILES"
                    echo "======================================================================"
                    echo "  [Comprehensive Reports]"
                    for f in comprehensive-report.html comprehensive-report.txt comprehensive-report.json; do
                        [ -f "${REPORTS_DIR}/$f" ] && echo "    $f"
                    done
                    echo "  [SBOM]"
                    ls "${REPORTS_DIR}/sbom/" 2>/dev/null | while read f; do echo "    sbom/$f"; done
                    echo "  [Trivy]"
                    ls "${REPORTS_DIR}/trivy/" 2>/dev/null | while read f; do echo "    trivy/$f"; done
                    echo "  [Unit Tests]"
                    ls "${REPORTS_DIR}"/pytest-*.xml "${REPORTS_DIR}"/pytest-*.html 2>/dev/null | while read f; do echo "    $(basename $f)"; done
                    echo "  [Secrets/SAST]"
                    [ -f "${REPORTS_DIR}/secret-scan.json" ] && echo "    secret-scan.json"
                    echo "  [SonarQube]"
                    ls "${REPORTS_DIR}/sonarqube/" 2>/dev/null | while read f; do echo "    sonarqube/$f"; done
                    echo "  [Other]"
                    for f in hadolint.txt hadolint.json shellcheck.json grype-sca.json grype-sca.txt bandit-report.json gate-results.txt kubesec-results.json pipeline-warnings.txt secret-scan.txt; do
                        [ -f "${REPORTS_DIR}/$f" ] && echo "    $f"
                    done
                    # List any per-Dockerfile hadolint JSON reports
                    ls "${REPORTS_DIR}"/hadolint-*.json 2>/dev/null | while read f; do echo "    $(basename $f)"; done
                    echo "======================================================================"
                '''
            }
        }
    }

    // =========================================================================
    // Post Actions
    // =========================================================================
    post {
        always {
            archiveArtifacts artifacts: 'pipeline-reports/**/*', allowEmptyArchive: true

            publishHTML(target: [
                allowMissing: true,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: 'pipeline-reports',
                reportFiles: 'comprehensive-report.html,pytest-report.html',
                reportName: 'DevSecOps Report'
            ])

            junit allowEmptyResults: true,
                  testResults: 'pipeline-reports/**/*.xml'

            // Copy reports to /opt/scan-reports/<scan_id> for API access
            script {
                def scanId = params.SCAN_ID ?: ''
                if (scanId) {
                    sh """
                        DEST="/opt/scan-reports/${scanId}"
                        mkdir -p "\${DEST}/sbom"
                        # Copy key report files (no raw console logs)
                        for f in '${REPORTS_DIR}'/*.json '${REPORTS_DIR}'/*.txt '${REPORTS_DIR}'/*.html; do
                            [ -f "\$f" ] && cp "\$f" "\${DEST}/" 2>/dev/null || true
                        done
                        # Copy trivy subdirectory
                        [ -d '${REPORTS_DIR}/trivy' ] && cp -r '${REPORTS_DIR}/trivy/'*.json "\${DEST}/" 2>/dev/null || true
                        # Copy SBOM
                        [ -d '${REPORTS_DIR}/sbom' ] && cp -r '${REPORTS_DIR}/sbom/'* "\${DEST}/sbom/" 2>/dev/null || true
                        echo "Reports copied to \${DEST}"
                    """
                }

                echo """
======================================================================
  Unified DevSecOps Pipeline Complete
  Reports:    pipeline-reports/comprehensive-report.html
  Warnings:   pipeline-reports/pipeline-warnings.txt
  Jenkins:    Build => DevSecOps Report
======================================================================
                """
            }
        }
        success  { echo '[OK] Unified DevSecOps Pipeline PASSED' }
        unstable { echo '[!!] Pipeline UNSTABLE — CRITICAL issues found. Review Comprehensive Report.' }
        failure  { echo '[!!] Pipeline FAILED — Check stage logs and pipeline-reports/pipeline-warnings.txt' }
        cleanup {
            cleanWs(deleteDirs: true, patterns: [
                [pattern: '.trivy-cache/**', type: 'INCLUDE'],
                [pattern: 'node_modules/**', type: 'INCLUDE']
            ])
        }
    }
}

// =============================================================================
// Helper: Auto-detect project language
// NOTE: The primary detection is now done via the Python module-discovery
//       engine in Stage 1 (modules.json). This helper is kept as a
//       last-resort fallback for any stage that calls it before modules.json
//       is available (should not normally occur).
// =============================================================================
def detectLanguage() {
    // Try modules.json first
    def mf = "${WORKSPACE}/pipeline-reports/modules.json"
    if (fileExists(mf)) {
        def lang = sh(script: """
python3 -c "
import json, sys
try:
    m = json.load(open('${mf}'))
    # prefer first non-root child module
    for k,v in m.items():
        if k != 'root':
            print(v['language']); sys.exit(0)
    if 'root' in m:
        print(m['root']['language']); sys.exit(0)
except: pass
print('python')
"
        """, returnStdout: true).trim()
        echo "Language from modules.json: ${lang}"
        return lang
    }

    // Fallback: root-level file checks (original logic)
    if (fileExists('requirements.txt') || fileExists('setup.py') ||
        fileExists('pyproject.toml') || fileExists('Pipfile')) {
        return 'python'
    }
    if (fileExists('pom.xml')) return 'java-maven'
    if (fileExists('build.gradle') || fileExists('build.gradle.kts')) return 'java-gradle'
    if (fileExists('angular.json')) return 'angular'
    if (fileExists('package.json')) {
        def pkg = readFile('package.json')
        if (pkg.contains('"react"')) return 'react'
        if (pkg.contains('"vue"'))   return 'vue'
        return 'nodejs'
    }
    if (fileExists('go.mod')) return 'go'
    if (sh(script: 'find . -maxdepth 3 -name "*.csproj" 2>/dev/null | head -1', returnStdout: true).trim()) {
        return 'dotnet'
    }
    return 'python'
}
