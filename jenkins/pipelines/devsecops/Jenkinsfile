// =============================================================================
// Jenkinsfile — Unified End-to-End DevSecOps Pipeline
// =============================================================================
//
//  PIPELINE STAGES:
//   0.  Bootstrap Agent (install ALL tools server-side — no local deps)
//   1.  Checkout & Language Detection
//   2.  Install Project Dependencies
//   3.  Lint & Code Quality
//   4.  Unit Testing + Coverage        (⚠ WARNING if tests folder missing)
//   5.  Integration Tests              (optional)
//   6.  CycloneDX SBOM Generation
//   7.  SonarQube Analysis             (optional)
//   8.  Build Application
//   9.  Docker / Container Build       (⚠ WARNING if no Dockerfile; Makefile-first)
//  10.  Trivy Image Scan               (only if image was built)
//  11.  SAST, Filesystem & Secret Scan
//  12.  SCA — Dependency Scan
//  13.  Dockerfile Lint                (⚠ WARNING if no Dockerfile)
//  14.  ShellCheck
//  15.  K8s Manifest Security Scan     (⚠ WARNING if no K8s manifests)
//  16.  Security Gate
//  17.  Deploy to K8s                  (optional)
//  18.  Comprehensive Final Report
//
//  Supports: Python · Java Maven/Gradle · Node.js · React · Angular · Go · .NET
//  All tools installed on the agent (server-side); zero local-machine dependencies.
// =============================================================================

pipeline {
    agent { label params.AGENT_LABEL ?: 'local-security-agent' }

    options {
        buildDiscarder(logRotator(numToKeepStr: '20'))
        timestamps()
        timeout(time: params.TIMEOUT_MINUTES?.toInteger() ?: 120, unit: 'MINUTES')
        ansiColor('xterm')
        skipDefaultCheckout(false)
    }

    environment {
        REGISTRY             = "${params.REGISTRY ?: '132.186.17.22:5000'}"
        REPORTS_DIR          = "${WORKSPACE}/pipeline-reports"
        COVERAGE_THRESHOLD   = "${params.COVERAGE_THRESHOLD ?: '70'}"
        SCAN_SEVERITY        = 'CRITICAL,HIGH'
        TRIVY_CACHE_DIR      = '/opt/trivy-cache'
        PIP_BREAK_SYSTEM_PACKAGES = '1'
    }

    parameters {
        string(name: 'GIT_REPO',               defaultValue: 'file:///tmp/jenkins-local-agent-code', description: 'Git repo URL (leave blank for workspace SCM)')
        string(name: 'GIT_BRANCH',             defaultValue: 'main',                 description: 'Branch to build')
        choice(name: 'LANGUAGE',               choices: ['auto','python','java-maven','java-gradle','nodejs','react','angular','go','dotnet'], description: 'Language (auto-detect if unsure)')
        string(name: 'IMAGE_NAME',             defaultValue: '',                     description: 'Docker image name (blank = skip image build)')
        string(name: 'IMAGE_TAG',              defaultValue: 'latest',               description: 'Docker image tag')
        string(name: 'REGISTRY',               defaultValue: '132.186.17.22:5000',   description: 'Container registry')
        string(name: 'DOCKERFILE_PATH',        defaultValue: 'Dockerfile',           description: 'Dockerfile path (Containerfile also accepted)')
        booleanParam(name: 'RUN_UNIT_TESTS',       defaultValue: true,  description: 'Run unit tests')
        booleanParam(name: 'RUN_INTEGRATION_TESTS', defaultValue: false, description: 'Run integration tests')
        string(name: 'COVERAGE_THRESHOLD',          defaultValue: '70',  description: 'Min code coverage %')
        string(name: 'PYTEST_ARGS',                 defaultValue: '',    description: 'Extra pytest arguments')
        booleanParam(name: 'RUN_TRIVY_SCAN',        defaultValue: true,  description: 'Trivy filesystem + image scan')
        booleanParam(name: 'RUN_SECRET_DETECTION',   defaultValue: true,  description: 'Secret detection scan')
        booleanParam(name: 'RUN_K8S_MANIFEST_SCAN',  defaultValue: true,  description: 'K8s manifest scan (warn if missing)')
        booleanParam(name: 'RUN_DOCKERFILE_LINT',     defaultValue: true,  description: 'Hadolint Dockerfile lint (warn if missing)')
        booleanParam(name: 'RUN_OWASP_CHECK',        defaultValue: false, description: 'OWASP Dependency-Check')
        booleanParam(name: 'RUN_GRYPE',               defaultValue: false, description: 'Grype vulnerability scan')
        booleanParam(name: 'FAIL_ON_CRITICAL',        defaultValue: true,  description: 'Fail build on CRITICAL vulns')
        booleanParam(name: 'GENERATE_SBOM',          defaultValue: true,  description: 'Generate CycloneDX SBOM')
        booleanParam(name: 'RUN_SONARQUBE',   defaultValue: true,  description: 'SonarQube analysis')
        string(name: 'SONAR_PROJECT_KEY',     defaultValue: '',    description: 'SonarQube project key (auto if blank)')
        booleanParam(name: 'DEPLOY_TO_K8S',   defaultValue: false, description: 'Deploy to Kubernetes')
        string(name: 'K8S_NAMESPACE',         defaultValue: '',    description: 'Kubernetes namespace')
        string(name: 'K8S_MANIFESTS_DIR',     defaultValue: 'cat-deployments', description: 'Path to K8s manifests')
        string(name: 'AGENT_LABEL',           defaultValue: 'local-security-agent', description: 'Jenkins agent label')
        string(name: 'TIMEOUT_MINUTES',       defaultValue: '120', description: 'Pipeline timeout (minutes)')
        booleanParam(name: 'FORCE_TOOL_REINSTALL', defaultValue: false, description: 'Force reinstall of agent tools')
        string(name: 'SCAN_ID',               defaultValue: '',    description: 'Unique scan identifier')
        string(name: 'SOURCE_UPLOAD_PATH',    defaultValue: '',    description: 'Path to uploaded source on server')
    }

    stages {

        // =====================================================================
        // STAGE 0: Bootstrap Agent — install ALL tools server-side
        // =====================================================================
        stage('Bootstrap Agent Tools') {
            steps {
                sh '''#!/usr/bin/env bash
set -uo pipefail

echo "===================================================================="
echo "  Stage 0: Bootstrap Agent — Installing All Tools (server-side)     "
echo "===================================================================="

BIN="/usr/local/bin"
mkdir -p "${BIN}" /opt/trivy-cache

# ── Trivy ──────────────────────────────────────────────────────────────────
if ! command -v trivy &>/dev/null || [ "${FORCE_TOOL_REINSTALL:-false}" = "true" ]; then
    echo "[INSTALL] Trivy..."
    cat > /etc/yum.repos.d/trivy.repo <<REPO
[trivy]
name=Trivy repository
baseurl=https://aquasecurity.github.io/trivy-repo/rpm/releases/\$basearch/
gpgcheck=0
enabled=1
REPO
    dnf install -y trivy 2>/dev/null || yum install -y trivy 2>/dev/null || {
        TRIVY_VER=$(curl -s https://api.github.com/repos/aquasecurity/trivy/releases/latest \
            | python3 -c "import sys,json; print(json.load(sys.stdin)['tag_name'].lstrip('v'))" 2>/dev/null || echo "0.62.1")
        curl -sfL "https://github.com/aquasecurity/trivy/releases/download/v${TRIVY_VER}/trivy_${TRIVY_VER}_Linux-64bit.tar.gz" \
            | tar xz -C "${BIN}" trivy 2>/dev/null || true
    }
fi
if command -v trivy &>/dev/null; then
    trivy image --download-db-only --quiet 2>/dev/null || true
    echo "[OK] Trivy: $(trivy --version 2>&1 | head -1)"
fi

# ── Hadolint ───────────────────────────────────────────────────────────────
if ! command -v hadolint &>/dev/null; then
    echo "[INSTALL] Hadolint..."
    HLVER=$(curl -s https://api.github.com/repos/hadolint/hadolint/releases/latest \
        | python3 -c "import sys,json; print(json.load(sys.stdin)['tag_name'])" 2>/dev/null || echo "v2.12.0")
    curl -sL "https://github.com/hadolint/hadolint/releases/download/${HLVER}/hadolint-Linux-x86_64" \
        -o "${BIN}/hadolint" && chmod +x "${BIN}/hadolint" || true
fi
command -v hadolint &>/dev/null && echo "[OK] Hadolint: $(hadolint --version 2>&1)" || echo "[WARN] Hadolint not available"

# ── ShellCheck ────────────────────────────────────────────────────────────
if ! command -v shellcheck &>/dev/null; then
    echo "[INSTALL] ShellCheck..."
    dnf install -y ShellCheck 2>/dev/null || yum install -y ShellCheck 2>/dev/null || {
        SCVER=$(curl -s https://api.github.com/repos/koalaman/shellcheck/releases/latest \
            | python3 -c "import sys,json; print(json.load(sys.stdin)['tag_name'])" 2>/dev/null || echo "v0.10.0")
        curl -sL "https://github.com/koalaman/shellcheck/releases/download/${SCVER}/shellcheck-${SCVER}.linux.x86_64.tar.xz" \
            | tar xJ --strip-components=1 -C "${BIN}" "shellcheck-${SCVER}/shellcheck" 2>/dev/null || true
    }
fi
command -v shellcheck &>/dev/null && echo "[OK] ShellCheck: $(shellcheck --version 2>&1 | head -2)" || echo "[WARN] ShellCheck not available"

# ── Kubesec ───────────────────────────────────────────────────────────────
if ! command -v kubesec &>/dev/null; then
    echo "[INSTALL] Kubesec..."
    KSVER=$(curl -s https://api.github.com/repos/controlplaneio/kubesec/releases/latest \
        | python3 -c "import sys,json; print(json.load(sys.stdin)['tag_name'].lstrip('v'))" 2>/dev/null || echo "2.14.1")
    curl -sL "https://github.com/controlplaneio/kubesec/releases/download/v${KSVER}/kubesec_linux_amd64.tar.gz" \
        | tar xz -C "${BIN}" kubesec 2>/dev/null && chmod +x "${BIN}/kubesec" || true
fi
command -v kubesec &>/dev/null && echo "[OK] Kubesec installed" || echo "[WARN] Kubesec not available"

# ── Grype ─────────────────────────────────────────────────────────────────
if ! command -v grype &>/dev/null; then
    echo "[INSTALL] Grype..."
    curl -sSfL https://raw.githubusercontent.com/anchore/grype/main/install.sh \
        | sh -s -- -b "${BIN}" 2>/dev/null || true
fi
command -v grype &>/dev/null && echo "[OK] Grype: $(grype version 2>&1 | head -1)" || echo "[WARN] Grype not available"

# ── SonarQube Scanner ────────────────────────────────────────────────────
if ! command -v sonar-scanner &>/dev/null; then
    echo "[INSTALL] SonarQube Scanner..."
    SONAR_VER="6.2.1.4610"
    SONAR_DIR="/opt/sonar-scanner"
    curl -sL "https://binaries.sonarsource.com/Distribution/sonar-scanner-cli/sonar-scanner-cli-${SONAR_VER}-linux-x64.zip" \
        -o /tmp/sonar-scanner.zip 2>/dev/null && \
        (command -v unzip &>/dev/null || dnf install -y unzip 2>/dev/null || yum install -y unzip 2>/dev/null) && \
        unzip -qo /tmp/sonar-scanner.zip -d /opt/ 2>/dev/null && \
        mv "/opt/sonar-scanner-${SONAR_VER}-linux-x64" "${SONAR_DIR}" 2>/dev/null && \
        ln -sf "${SONAR_DIR}/bin/sonar-scanner" "${BIN}/sonar-scanner" 2>/dev/null || true
    rm -f /tmp/sonar-scanner.zip
fi
command -v sonar-scanner &>/dev/null && echo "[OK] SonarQube Scanner installed" || echo "[WARN] sonar-scanner not available"

# ── Python security / SBOM tools (system-wide on agent) ──────────────────
echo "[INSTALL] Python security/SBOM tools (agent system)..."
PIP_FLAGS="--quiet --break-system-packages"
pip install ${PIP_FLAGS} --upgrade pip 2>/dev/null || pip install --quiet --upgrade pip 2>/dev/null || true
pip install ${PIP_FLAGS} \
    pytest pytest-cov pytest-html pytest-xdist pytest-json-report \
    flake8 black mypy bandit safety pylint \
    cyclonedx-bom cyclonedx-py pip-audit \
    2>/dev/null || \
pip install --quiet \
    pytest pytest-cov pytest-html pytest-xdist pytest-json-report \
    flake8 black mypy bandit safety pylint \
    cyclonedx-bom cyclonedx-py pip-audit \
    2>/dev/null || true
echo "[OK] Python tools installed"

# ── Node.js global CycloneDX npm ──────────────────────────────────────────
if command -v npm &>/dev/null; then
    npm install -g @cyclonedx/cyclonedx-npm 2>/dev/null || true
    echo "[OK] @cyclonedx/cyclonedx-npm installed globally"
fi

# ── Go CycloneDX ──────────────────────────────────────────────────────────
if command -v go &>/dev/null; then
    go install github.com/CycloneDX/cyclonedx-gomod/cmd/cyclonedx-gomod@latest 2>/dev/null || true
    echo "[OK] cyclonedx-gomod installed"
fi

# ── jq ────────────────────────────────────────────────────────────────────
if ! command -v jq &>/dev/null; then
    dnf install -y jq 2>/dev/null || yum install -y jq 2>/dev/null || true
fi
command -v jq &>/dev/null && echo "[OK] jq: $(jq --version)"

# ── OWASP Dependency-Check ────────────────────────────────────────────────
DC_DIR="/opt/dependency-check"
if [ ! -f "${DC_DIR}/bin/dependency-check.sh" ]; then
    echo "[INSTALL] OWASP Dependency-Check..."
    DC_VER=$(curl -s https://api.github.com/repos/jeremylong/DependencyCheck/releases/latest \
        | python3 -c "import sys,json; print(json.load(sys.stdin)['tag_name'].lstrip('v'))" 2>/dev/null || echo "11.1.1")
    curl -sL "https://github.com/jeremylong/DependencyCheck/releases/download/v${DC_VER}/dependency-check-${DC_VER}-release.zip" \
        -o /tmp/dc.zip 2>/dev/null && \
        unzip -qo /tmp/dc.zip -d /opt/ 2>/dev/null && \
        ln -sf "${DC_DIR}/bin/dependency-check.sh" "/usr/local/bin/dependency-check.sh" 2>/dev/null || true
    rm -f /tmp/dc.zip
fi
[ -f "${DC_DIR}/bin/dependency-check.sh" ] && echo "[OK] OWASP DC installed" || echo "[WARN] OWASP DC not available"

echo ""
echo "===================================================================="
echo "  Bootstrap Complete — Tool Inventory"
echo "===================================================================="
for tool in trivy hadolint shellcheck kubesec grype sonar-scanner jq python3 pip node npm go java podman docker; do
    if command -v "$tool" &>/dev/null; then
        printf "  [OK]    %-20s  %s\n" "$tool" "$(command -v $tool)"
    else
        printf "  [miss]  %-20s  not on PATH\n" "$tool"
    fi
done
echo "===================================================================="
'''
            }
        }

        // =====================================================================
        // STAGE 1: Checkout & Language Detection
        // =====================================================================
        stage('Checkout & Discover Modules') {
            steps {
                script {
                    // Extract uploaded source if provided
                    if (params.SOURCE_UPLOAD_PATH?.trim()) {
                        def uploadPath = params.SOURCE_UPLOAD_PATH.trim()
                        def tarFile = uploadPath + '/source.tar.gz'
                        sh """
                            if [ -f '${tarFile}' ]; then
                                echo "=== Extracting uploaded source code ==="
                                tar xzf '${tarFile}' -C '${WORKSPACE}' 2>/dev/null || true
                                echo "Extracted: \$(find '${WORKSPACE}' -maxdepth 3 -type f | wc -l) files"
                            fi
                        """
                    } else if (params.GIT_REPO?.trim()) {
                        checkout([
                            $class: 'GitSCM',
                            branches: [[name: "*/${params.GIT_BRANCH}"]],
                            userRemoteConfigs: [[url: params.GIT_REPO]],
                            extensions: [[$class: 'CloneOption', depth: 1, shallow: true]]
                        ])
                    }

                    sh """
                        mkdir -p '${REPORTS_DIR}'
                        mkdir -p '${REPORTS_DIR}/sbom'
                        mkdir -p '${REPORTS_DIR}/sonarqube'
                        mkdir -p '${REPORTS_DIR}/trivy'
                    """

                    // =========================================================
                    // Dynamic Module Discovery — Python scans EVERY subdirectory
                    // Produces: pipeline-reports/modules.json
                    // Schema per module:
                    //   key, dir, language, makefiles[], dockerfiles[],
                    //   test_dirs[], dep_files[]
                    // =========================================================
                    sh """
export REPORTS_DIR='${REPORTS_DIR}'
export WORKSPACE='${WORKSPACE}'
python3 <<'DISCOVERY_EOF'
import os, json, glob, re, sys

WORKSPACE   = os.environ['WORKSPACE']
REPORTS_DIR = os.environ['REPORTS_DIR']

# Never descend into these directories
SKIP_DIRS = {
    'node_modules', '.git', 'pipeline-reports', '.trivy-cache',
    '.venv', 'venv', 'env', '.env', '__pycache__', '.scannerwork',
    '.mypy_cache', '.pytest_cache', 'dist', 'build', 'target',
    '.gradle', '.mvn', 'obj', 'bin', '.idea', '.vscode',
    'htmlcov', 'coverage', '.nyc_output', '.tox', 'eggs',
    '.eggs', 'bower_components', 'vendor'
}

# Ordered list: most-specific lang-marker first
LANG_MARKERS = [
    ('pom.xml',           'java-maven'),
    ('build.gradle',      'java-gradle'),
    ('build.gradle.kts',  'java-gradle'),
    ('angular.json',      'angular'),
    ('go.mod',            'go'),
    ('requirements.txt',  'python'),
    ('setup.py',          'python'),
    ('pyproject.toml',    'python'),
    ('Pipfile',           'python'),
    ('package.json',      'nodejs'),   # react/vue refined below
]

def detect_lang(d):
    for marker, lang in LANG_MARKERS:
        if os.path.isfile(os.path.join(d, marker)):
            if lang == 'nodejs':
                try:
                    pkg = open(os.path.join(d, 'package.json')).read()
                    if '"react"' in pkg or '"react-dom"' in pkg: return 'react'
                    if '"vue"' in pkg: return 'vue'
                except: pass
            return lang
    # dotnet: any .csproj in the dir
    if glob.glob(os.path.join(d, '*.csproj')):
        return 'dotnet'
    return None

def find_test_dirs(module_dir, lang):
    """Walk module_dir and collect all directories that contain test code."""
    found = set()
    test_dir_names = {'tests', 'test', '__tests__', 'spec', 'specs', 'e2e'}
    for root, dirs, files in os.walk(module_dir):
        # Prune unwanted dirs in-place
        dirs[:] = sorted(d for d in dirs if d not in SKIP_DIRS and not d.startswith('.'))
        base = os.path.basename(root)
        rel  = os.path.relpath(root, WORKSPACE)

        if lang == 'python':
            py_test_files = [f for f in files
                             if f.startswith('test_') or f.endswith('_test.py')
                             or f == 'conftest.py']
            if py_test_files:
                # prefer the named test dir; otherwise include parent
                if base in test_dir_names:
                    found.add(rel)
                else:
                    # flat test files (e.g. root has test_main.py)
                    if any(f.startswith('test_') for f in py_test_files):
                        found.add(rel)

        elif lang in ('nodejs', 'react', 'angular', 'vue'):
            if base in test_dir_names:
                found.add(rel)
            if any(f.endswith(('.test.js','.test.ts','.spec.js','.spec.ts',
                               '.test.jsx','.test.tsx','.spec.jsx','.spec.tsx'))
                   for f in files):
                found.add(rel)

        elif lang in ('java-maven', 'java-gradle'):
            parts = rel.replace('\\\\', '/').split('/')
            if 'src' in parts and 'test' in parts and files:
                found.add(rel)

        elif lang == 'go':
            if any(f.endswith('_test.go') for f in files):
                found.add(rel)

        elif lang == 'dotnet':
            if base in test_dir_names or any(
                    'Test' in f and f.endswith('.csproj') for f in files):
                found.add(rel)

    return sorted(found)

def get_makefiles(module_dir):
    """Find all Makefiles in module_dir tree and inspect their targets."""
    result = []
    for root, dirs, files in os.walk(module_dir):
        dirs[:] = sorted(d for d in dirs if d not in SKIP_DIRS and not d.startswith('.'))
        if 'Makefile' not in files:
            continue
        mf_abs  = os.path.join(root, 'Makefile')
        mf_path = os.path.relpath(mf_abs, WORKSPACE)
        mf_dir  = os.path.relpath(root, WORKSPACE)
        if mf_dir == '.': mf_dir = ''
        targets = []
        try:
            content = open(mf_abs).read()
            for tgt in ['docker-build','build-image','scan','image','docker',
                        'container','push','build','all','test','lint']:
                if re.search(r'^' + re.escape(tgt) + r'\\s*:', content, re.MULTILINE):
                    targets.append(tgt)
        except: pass
        build_target  = next((t for t in targets
                              if t in ('build','all')), '')
        docker_target = next((t for t in targets
                              if t in ('docker-build','build-image','image',
                                       'docker','container')), '')
        scan_target   = next((t for t in targets if t == 'scan'), '')
        result.append({
            'path': mf_path, 'dir': mf_dir, 'targets': targets,
            'build_target': build_target, 'docker_target': docker_target,
            'scan_target': scan_target
        })
    return result

def get_dockerfiles(module_dir):
    """Find all Dockerfiles in module_dir tree."""
    found = []
    for root, dirs, files in os.walk(module_dir):
        dirs[:] = sorted(d for d in dirs if d not in SKIP_DIRS and not d.startswith('.'))
        for f in files:
            if f == 'Dockerfile' or f == 'Containerfile' or f.startswith('Dockerfile.'):
                found.append(os.path.relpath(os.path.join(root, f), WORKSPACE))
    return sorted(found)

def get_dep_files(module_dir, lang):
    dep_files = []
    if lang == 'python':
        for name in ['requirements.txt','requirements-dev.txt',
                     'requirements-test.txt','setup.py','pyproject.toml','Pipfile']:
            fp = os.path.join(module_dir, name)
            if os.path.isfile(fp):
                dep_files.append(os.path.relpath(fp, WORKSPACE))
        # also look one level deeper (e.g. backend/requirements.txt)
        for sub in os.listdir(module_dir):
            sd = os.path.join(module_dir, sub)
            if not os.path.isdir(sd) or sub in SKIP_DIRS or sub.startswith('.'): continue
            for name in ['requirements.txt','requirements-dev.txt']:
                fp = os.path.join(sd, name)
                if os.path.isfile(fp):
                    dep_files.append(os.path.relpath(fp, WORKSPACE))
    elif lang in ('nodejs','react','angular','vue'):
        fp = os.path.join(module_dir, 'package.json')
        if os.path.isfile(fp):
            dep_files.append(os.path.relpath(fp, WORKSPACE))
    elif lang == 'java-maven':
        fp = os.path.join(module_dir, 'pom.xml')
        if os.path.isfile(fp): dep_files.append(os.path.relpath(fp, WORKSPACE))
    elif lang == 'java-gradle':
        for n in ('build.gradle','build.gradle.kts'):
            fp = os.path.join(module_dir, n)
            if os.path.isfile(fp): dep_files.append(os.path.relpath(fp, WORKSPACE))
    elif lang == 'go':
        fp = os.path.join(module_dir, 'go.mod')
        if os.path.isfile(fp): dep_files.append(os.path.relpath(fp, WORKSPACE))
    elif lang == 'dotnet':
        dep_files += [os.path.relpath(c, WORKSPACE)
                      for c in glob.glob(os.path.join(module_dir, '*.csproj'))]
    return dep_files

# ── Module scanning ────────────────────────────────────────────────────────
modules = {}

def scan_module(d, key):
    lang = detect_lang(d)
    if not lang:
        return
    rel = os.path.relpath(d, WORKSPACE)
    if rel == '.': rel = ''
    modules[key] = {
        'key':        key,
        'dir':        rel,
        'language':   lang,
        'makefiles':  get_makefiles(d),
        'dockerfiles':get_dockerfiles(d),
        'test_dirs':  find_test_dirs(d, lang),
        'dep_files':  get_dep_files(d, lang),
    }

# Always scan workspace root
scan_module(WORKSPACE, 'root')

# Scan every immediate subdirectory — catches frontend/, backend/, api/, etc.
for entry in sorted(os.listdir(WORKSPACE)):
    full = os.path.join(WORKSPACE, entry)
    if os.path.isdir(full) and entry not in SKIP_DIRS and not entry.startswith('.'):
        scan_module(full, entry)

# Deduplication: if a child module has EXACTLY the same dockerfiles/makefiles as root,
# remove duplicates from root to avoid double-builds (keep child's entry only).
root_dfs  = set(modules.get('root', {}).get('dockerfiles', []))
root_mfs  = set(x['path'] for x in modules.get('root', {}).get('makefiles', []))
for key, m in list(modules.items()):
    if key == 'root': continue
    child_dfs = set(m.get('dockerfiles', []))
    child_mfs = set(x['path'] for x in m.get('makefiles', []))
    # Remove from root anything that also appears in a proper child module
    if 'root' in modules:
        modules['root']['dockerfiles'] = [d for d in modules['root']['dockerfiles']
                                           if d not in child_dfs]
        modules['root']['makefiles']   = [mf for mf in modules['root']['makefiles']
                                           if mf['path'] not in child_mfs]

# Write modules.json
os.makedirs(REPORTS_DIR, exist_ok=True)
mf = os.path.join(REPORTS_DIR, 'modules.json')
with open(mf, 'w') as f:
    json.dump(modules, f, indent=2)

# Console summary
print('=' * 70)
print(f'  WORKSPACE MODULE DISCOVERY — {len(modules)} module(s)')
print('=' * 70)
all_test_dirs = []
all_dockerfiles = []
all_makefiles   = []
for k,m in modules.items():
    print(f'  [{k}]  dir={m["dir"] or "."}  lang={m["language"]}')
    if m['test_dirs']:
        print(f'    tests:       {m["test_dirs"]}')
        all_test_dirs.extend(m['test_dirs'])
    if m['makefiles']:
        for mf2 in m['makefiles']:
            print(f'    makefile:    {mf2["path"]}  targets={mf2["targets"]}')
            all_makefiles.append(mf2['path'])
    if m['dockerfiles']:
        print(f'    dockerfiles: {m["dockerfiles"]}')
        all_dockerfiles.extend(m['dockerfiles'])
    if m['dep_files']:
        print(f'    dep files:   {m["dep_files"]}')
print('=' * 70)
if not all_test_dirs:
    print('  [WARNING] No test directories found in any module')
if not all_dockerfiles:
    print('  [WARNING] No Dockerfiles found in any module')

DISCOVERY_EOF
"""

                    // =========================================================
                    // Read modules.json back into Groovy env vars
                    // =========================================================
                    env.MODULES_JSON = readFile("${REPORTS_DIR}/modules.json").trim()

                    // Primary language = first non-root module's language, or root
                    env.DETECTED_LANG = sh(script: """
python3 -c "
import json, sys
modules = json.loads(open('${REPORTS_DIR}/modules.json').read())
# Prefer explicit param
param = '${params.LANGUAGE}'
if param != 'auto':
    print(param)
    sys.exit(0)
# First child module wins; fall back to root
for k,m in modules.items():
    if k != 'root':
        print(m['language']); sys.exit(0)
if 'root' in modules:
    print(modules['root']['language']); sys.exit(0)
print('python')
"
                    """, returnStdout: true).trim()

                    // Flat list of ALL dockerfiles across ALL modules
                    env.ALL_DOCKERFILES = sh(script: """
python3 -c "
import json
modules = json.loads(open('${REPORTS_DIR}/modules.json').read())
dfs = []
for m in modules.values():
    dfs.extend(m.get('dockerfiles', []))
print(' '.join(sorted(set(dfs))))
"
                    """, returnStdout: true).trim()
                    env.HAS_DOCKERFILE = env.ALL_DOCKERFILES ? 'true' : 'false'

                    // Flat list of ALL makefile paths across ALL modules
                    env.ALL_MAKEFILES = sh(script: """
python3 -c "
import json
modules = json.loads(open('${REPORTS_DIR}/modules.json').read())
mfs = []
for m in modules.values():
    mfs.extend(x['path'] for x in m.get('makefiles', []))
print(' '.join(sorted(set(mfs))))
"
                    """, returnStdout: true).trim()
                    env.HAS_MAKEFILE = env.ALL_MAKEFILES ? 'true' : 'false'

                    // Any test dirs?
                    env.HAS_TESTS = sh(script: """
python3 -c "
import json
modules = json.loads(open('${REPORTS_DIR}/modules.json').read())
tds = [d for m in modules.values() for d in m.get('test_dirs', [])]
print('true' if tds else 'false')
"
                    """, returnStdout: true).trim()

                    // K8s manifests (still parameter-driven for deploy stage)
                    def k8sDir = params.K8S_MANIFESTS_DIR ?: 'cat-deployments'
                    env.K8S_MANIFESTS_DIR = k8sDir
                    env.HAS_K8S_MANIFESTS = sh(script: """
                        find '${k8sDir}' \\( -name '*.yml' -o -name '*.yaml' \\) 2>/dev/null | head -1 | grep -q . && echo true || echo false
                    """, returnStdout: true).trim()

                    env.PIPELINE_START = sh(script: 'date +%s', returnStdout: true).trim()

                    sh """
                        {
                          echo "=== Pipeline Warnings ==="
                          [ '${env.HAS_DOCKERFILE}' = 'false' ] && echo "[WARNING] No Dockerfiles found in workspace — Docker build will be SKIPPED"
                          [ '${env.HAS_K8S_MANIFESTS}' = 'false' ] && echo "[WARNING] No K8s manifests in '${k8sDir}/' — K8s scan will be SKIPPED"
                          [ '${env.HAS_TESTS}' = 'false' ] && echo "[WARNING] No test directories found in any module — tests will be SKIPPED"
                          [ '${env.HAS_MAKEFILE}' = 'false' ] && echo "[INFO] No Makefiles found — using standard language build commands"
                          echo "========================="
                        } | tee '${REPORTS_DIR}/pipeline-warnings.txt'
                    """

                    // Pretty-print discovery summary
                    sh """
python3 <<'SUMMARY_EOF'
import json
m = json.loads(open('${REPORTS_DIR}/modules.json').read())
sep = '=' * 70
print(sep)
print('  Unified DevSecOps Pipeline — Discovered Modules')
print(sep)
for k, mod in m.items():
    tds = ', '.join(mod['test_dirs']) or '(none)'
    dfs = ', '.join(mod['dockerfiles']) or '(none)'
    mks = ', '.join(x['path'] for x in mod['makefiles']) or '(none)'
    print(f'  Module : {k}')
    print(f'    Dir        : {mod["dir"] or "."}')
    print(f'    Language   : {mod["language"]}')
    print(f'    Tests      : {tds}')
    print(f'    Makefiles  : {mks}')
    print(f'    Dockerfiles: {dfs}')
    print()
print(sep)
SUMMARY_EOF
"""
                }
            }
        }

        // =====================================================================
        // STAGE 2: Install Project Dependencies (per discovered module)
        // =====================================================================
        stage('Install Project Dependencies') {
            steps {
                sh """
export REPORTS_DIR='${REPORTS_DIR}'
export WORKSPACE='${WORKSPACE}'
python3 <<'DEPS_EOF'
import json, subprocess, os, sys

WORKSPACE   = os.environ['WORKSPACE']
REPORTS_DIR = os.environ['REPORTS_DIR']
modules     = json.loads(open(os.path.join(REPORTS_DIR, 'modules.json')).read())

def run(cmd, cwd=None):
    print(f'  \\$ {cmd}')
    result = subprocess.run(cmd, shell=True, cwd=cwd or WORKSPACE)
    return result.returncode

PIP = 'pip install --break-system-packages --quiet'

for key, m in modules.items():
    lang = m['language']
    d    = os.path.join(WORKSPACE, m['dir']) if m['dir'] else WORKSPACE
    print()
    print(f'{"="*60}')
    print(f'  [deps] Module: {key}  lang={lang}  dir={m["dir"] or "."}')
    print(f'{"="*60}')

    if lang == 'python':
        for dep_file in m.get('dep_files', []):
            full = os.path.join(WORKSPACE, dep_file)
            if not os.path.isfile(full): continue
            name = os.path.basename(dep_file)
            if name in ('requirements.txt','requirements-dev.txt','requirements-test.txt'):
                run(f'{PIP} -r "{full}"')
            elif name in ('setup.py', 'pyproject.toml'):
                run(f'{PIP} -e ".[dev,test]" || {PIP} -e .', cwd=d)
            elif name == 'Pipfile':
                run(f'pipenv install --dev', cwd=d)
        # Also install any additional requirements in sub-subdirs not yet listed
        for root, dirs, files in os.walk(d):
            dirs[:] = [x for x in dirs if x not in {'node_modules','.venv','venv',
                       '.git','pipeline-reports','.trivy-cache','__pycache__'}]
            if root == d: continue  # root already handled above
            for f in files:
                if f.startswith('requirements') and f.endswith('.txt'):
                    run(f'{PIP} -r "{os.path.join(root, f)}"')

    elif lang == 'java-maven':
        run('mvn dependency:resolve -q', cwd=d)

    elif lang == 'java-gradle':
        run('chmod +x gradlew 2>/dev/null; ./gradlew dependencies --quiet 2>/dev/null || gradle dependencies --quiet 2>/dev/null', cwd=d)

    elif lang in ('nodejs', 'react', 'angular', 'vue'):
        if os.path.isfile(os.path.join(d, 'yarn.lock')):
            run('yarn install --frozen-lockfile || yarn install', cwd=d)
        elif os.path.isfile(os.path.join(d, 'pnpm-lock.yaml')):
            run('pnpm install --frozen-lockfile || pnpm install', cwd=d)
        elif os.path.isfile(os.path.join(d, 'package.json')):
            run('npm ci || npm install', cwd=d)
        # Also install in any nested package dirs (e.g. frontend/src/widget)
        for root, dirs, files in os.walk(d):
            dirs[:] = [x for x in dirs if x not in {'node_modules','.git',
                       'pipeline-reports','.trivy-cache'}]
            if root == d: continue
            if 'package.json' in files:
                run('npm ci || npm install', cwd=root)

    elif lang == 'go':
        if os.path.isfile(os.path.join(d, 'go.mod')):
            run('go mod download && go mod verify', cwd=d)

    elif lang == 'dotnet':
        proj = next(iter(m.get('dep_files', [])), None)
        if proj:
            run(f'dotnet restore "{os.path.join(WORKSPACE, proj)}"')

print()
print('  [OK] All module dependencies installed')
DEPS_EOF
"""
            }
        }

        // =====================================================================
        // STAGE 3: Lint & Code Quality (per discovered module)
        // =====================================================================
        stage('Lint & Code Quality') {
            steps {
                sh """
export REPORTS_DIR='${REPORTS_DIR}'
export WORKSPACE='${WORKSPACE}'
python3 <<'LINT_EOF'
import json, subprocess, os

WORKSPACE   = os.environ['WORKSPACE']
REPORTS_DIR = os.environ['REPORTS_DIR']
modules     = json.loads(open(os.path.join(REPORTS_DIR, 'modules.json')).read())

def run(cmd, cwd=None, capture=False):
    print(f'  \\$ {cmd}')
    kwargs = dict(shell=True, cwd=cwd or WORKSPACE)
    if capture:
        r = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, **kwargs)
        return r.returncode, (r.stdout or b'').decode(errors='replace')
    return subprocess.run(cmd, **kwargs).returncode, ''

for key, m in modules.items():
    lang = m['language']
    d    = os.path.join(WORKSPACE, m['dir']) if m['dir'] else WORKSPACE
    print()
    print(f'{"="*60}')
    print(f'  [lint] Module: {key}  lang={lang}  dir={m["dir"] or "."}')
    print(f'{"="*60}')

    safe = key.replace('/', '-')

    if lang == 'python':
        src = m['dir'] or '.'
        excl = '.venv,venv,__pycache__,migrations,.trivy-cache,pipeline-reports,.git'
        run(f'flake8 "{d}" --max-line-length=120 --exclude={excl} '
            f'--output-file="{REPORTS_DIR}/flake8-{safe}.txt"')
        run(f'bandit -r "{d}" -f json -o "{REPORTS_DIR}/bandit-{safe}.json" '
            f'--exclude .venv,venv,tests,test,.trivy-cache,pipeline-reports')
        py_files = subprocess.run(
            f'find "{d}" -name "*.py" -not -path "*/.venv/*" -not -path "*/venv/*" '
            f'-not -path "*/pipeline-reports/*" -not -path "*/__pycache__/*"',
            shell=True, cwd=WORKSPACE, stdout=subprocess.PIPE
        ).stdout.decode().split()[:30]
        if py_files:
            files_str = ' '.join('"' + f + '"' for f in py_files)
            run(f'pylint --output-format=text --score=yes {files_str} '
                f'> "{REPORTS_DIR}/pylint-{safe}.txt" 2>&1')

    elif lang == 'java-maven':
        run('mvn checkstyle:check -q', cwd=d)

    elif lang == 'java-gradle':
        run('./gradlew checkstyleMain 2>/dev/null || gradle checkstyleMain', cwd=d)

    elif lang in ('nodejs', 'react', 'angular', 'vue'):
        if os.path.isfile(os.path.join(d, 'node_modules', '.bin', 'eslint')):
            run(f'npx eslint . --format json '
                f'--output-file "{REPORTS_DIR}/eslint-{safe}.json"', cwd=d)
        elif os.path.isfile(os.path.join(d, 'node_modules', '.bin', 'tslint')):
            run(f'npx tslint -t json -o "{REPORTS_DIR}/tslint-{safe}.json" '
                f'"src/**/*.ts"', cwd=d)

    elif lang == 'go':
        run(f'go vet ./... > "{REPORTS_DIR}/govet-{safe}.txt" 2>&1', cwd=d)
        run(f'golangci-lint run --out-format json > "{REPORTS_DIR}/golangci-{safe}.json" 2>&1', cwd=d)

    elif lang == 'dotnet':
        run('dotnet format --verify-no-changes', cwd=d)

print()
print('  [OK] Lint complete for all modules')
LINT_EOF
"""
            }
        }

        // =====================================================================
        // STAGE 4: Unit Testing & Coverage (per module, per test dir)
        // =====================================================================
        stage('Unit Testing & Coverage') {
            when { expression { params.RUN_UNIT_TESTS } }
            steps {
                sh """
export REPORTS_DIR='${REPORTS_DIR}'
export WORKSPACE='${WORKSPACE}'
export COVERAGE_THRESHOLD='${COVERAGE_THRESHOLD}'
export PYTEST_ARGS='${params.PYTEST_ARGS ?: ''}'
python3 <<'TEST_EOF'
import json, subprocess, os, sys

WORKSPACE         = os.environ['WORKSPACE']
REPORTS_DIR       = os.environ['REPORTS_DIR']
COVERAGE_THRESHOLD= os.environ.get('COVERAGE_THRESHOLD', '70')
PYTEST_ARGS       = os.environ.get('PYTEST_ARGS', '')
modules           = json.loads(open(os.path.join(REPORTS_DIR, 'modules.json')).read())

def run(cmd, cwd=None):
    print(f'  \\$ {cmd}')
    rc = subprocess.run(cmd, shell=True, cwd=cwd or WORKSPACE).returncode
    print(f'     → exit {rc}')
    return rc

found_tests = False

for key, m in modules.items():
    lang     = m['language']
    mod_dir  = os.path.join(WORKSPACE, m['dir']) if m['dir'] else WORKSPACE
    test_dirs= m.get('test_dirs', [])
    safe     = key.replace('/', '-')

    if not test_dirs:
        print(f'  [SKIP] Module {key}: no test directories found')
        continue

    found_tests = True
    print()
    print(f'{"="*60}')
    print(f'  [test] Module: {key}  lang={lang}')
    print(f'  Test dirs: {test_dirs}')
    print(f'{"="*60}')

    if lang == 'python':
        # Run pytest over ALL test dirs for this module in one invocation
        test_paths = ' '.join(f'"{os.path.join(WORKSPACE, td)}"' for td in test_dirs)
        cov_src    = m['dir'] or '.'
        run(
            f'python3 -m pytest {test_paths} '
            f'--junitxml="{REPORTS_DIR}/pytest-{safe}-results.xml" '
            f'--html="{REPORTS_DIR}/pytest-{safe}-report.html" --self-contained-html '
            f'--cov="{cov_src}" '
            f'--cov-report=xml:"{REPORTS_DIR}/coverage-{safe}.xml" '
            f'--cov-report=html:"{REPORTS_DIR}/htmlcov-{safe}" '
            f'--cov-report=term-missing '
            f'--cov-fail-under={COVERAGE_THRESHOLD} '
            f'--tb=short -v {PYTEST_ARGS}',
            cwd=WORKSPACE
        )

    elif lang == 'java-maven':
        run('mvn test jacoco:report -Dmaven.test.failure.ignore=true', cwd=mod_dir)
        run(f'cp -r target/surefire-reports/* "{REPORTS_DIR}/" 2>/dev/null; '
            f'cp target/site/jacoco/jacoco.xml "{REPORTS_DIR}/jacoco-{safe}.xml" 2>/dev/null',
            cwd=mod_dir)

    elif lang == 'java-gradle':
        run('./gradlew test jacocoTestReport --continue 2>/dev/null || '
            'gradle test jacocoTestReport --continue', cwd=mod_dir)
        run(f'cp -r build/test-results/test/* "{REPORTS_DIR}/" 2>/dev/null; '
            f'cp build/reports/jacoco/test/jacocoTestReport.xml '
            f'"{REPORTS_DIR}/jacoco-{safe}.xml" 2>/dev/null',
            cwd=mod_dir)

    elif lang in ('nodejs', 'react', 'angular', 'vue'):
        pkg_json = os.path.join(mod_dir, 'package.json')
        if os.path.isfile(pkg_json):
            pkg = open(pkg_json).read()
            if '"test"' in pkg:
                run(
                    f'npx jest --ci --coverage '
                    f'--coverageDirectory="{REPORTS_DIR}/coverage-{safe}" '
                    f'--coverageReporters=json-summary --coverageReporters=lcov '
                    f'--reporters=default --reporters=jest-junit '
                    f'--passWithNoTests 2>/dev/null || '
                    f'npm test -- --watchAll=false --passWithNoTests 2>/dev/null || '
                    f'npm test',
                    cwd=mod_dir
                )
            else:
                print(f'  [INFO] No "test" script in {pkg_json}')

    elif lang == 'go':
        run(
            f'go test ./... -v -count=1 '
            f'-coverprofile="{REPORTS_DIR}/go-coverage-{safe}.out" '
            f'-json > "{REPORTS_DIR}/go-test-{safe}.json" 2>&1',
            cwd=mod_dir
        )
        run(f'go tool cover -func="{REPORTS_DIR}/go-coverage-{safe}.out" 2>/dev/null | tail -5',
            cwd=mod_dir)
        run(f'go tool cover -html="{REPORTS_DIR}/go-coverage-{safe}.out" '
            f'-o "{REPORTS_DIR}/go-coverage-{safe}.html" 2>/dev/null',
            cwd=mod_dir)

    elif lang == 'dotnet':
        run(
            f'dotnet test '
            f'--logger "trx;LogFileName={REPORTS_DIR}/dotnet-{safe}.trx" '
            f'--collect:"XPlat Code Coverage" '
            f'--results-directory "{REPORTS_DIR}" -v normal',
            cwd=mod_dir
        )

if not found_tests:
    print()
    print('====================================================================')
    print('  [WARNING] No test directories found in any module')
    print('  Ensure your project has one of:')
    print('    Python   : tests/ or test/ with test_*.py files')
    print('    Node.js  : __tests__/ or *.test.js / *.spec.js files')
    print('    Java     : src/test/java/ with *Test.java files')
    print('    Go       : *_test.go files')
    print('    .NET     : tests/ or *Tests.csproj project')
    print('====================================================================')
    with open(os.path.join(REPORTS_DIR, 'test-status.txt'), 'w') as f:
        f.write('NO_TESTS_FOUND')
    with open(os.path.join(REPORTS_DIR, 'pipeline-warnings.txt'), 'a') as f:
        f.write('[WARNING] No tests found in any module\\n')

TEST_EOF
"""
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: "pipeline-reports/**/*.xml"
                }
            }
        }

        // =====================================================================
        // STAGE 5: Integration Tests (optional, per module)
        // =====================================================================
        stage('Integration Tests') {
            when { expression { params.RUN_INTEGRATION_TESTS } }
            steps {
                sh """
export REPORTS_DIR='${REPORTS_DIR}'
export WORKSPACE='${WORKSPACE}'
python3 <<'INTTEST_EOF'
import json, subprocess, os, glob

WORKSPACE   = os.environ['WORKSPACE']
REPORTS_DIR = os.environ['REPORTS_DIR']
modules     = json.loads(open(os.path.join(REPORTS_DIR, 'modules.json')).read())

def run(cmd, cwd=None):
    print(f'  \\$ {cmd}')
    return subprocess.run(cmd, shell=True, cwd=cwd or WORKSPACE).returncode

int_names = {'integration', 'e2e', 'functional', 'acceptance', 'api'}

for key, m in modules.items():
    lang    = m['language']
    d       = os.path.join(WORKSPACE, m['dir']) if m['dir'] else WORKSPACE
    safe    = key.replace('/', '-')

    # Find integration test dirs inside this module
    int_dirs = [td for td in m.get('test_dirs', [])
                if any(n in td.lower() for n in int_names)]

    # Fallback: search for integration patterns
    if not int_dirs:
        for root, dirs, files in os.walk(d):
            dirs[:] = [x for x in dirs if x not in {'node_modules','.git','pipeline-reports','.trivy-cache','.venv','venv'}]
            base = os.path.basename(root)
            if base in int_names:
                int_dirs.append(os.path.relpath(root, WORKSPACE))

    if not int_dirs:
        print(f'  [SKIP] Module {key}: no integration test dirs found')
        continue

    print(f'  [int-test] Module {key}  lang={lang}  dirs={int_dirs}')

    if lang == 'python':
        paths = ' '.join('"' + os.path.join(WORKSPACE, td) + '"' for td in int_dirs)
        run(f'python3 -m pytest {paths} '
            f'--junitxml="{REPORTS_DIR}/pytest-integration-{safe}.xml" '
            f'-v -m integration', cwd=WORKSPACE)

    elif lang == 'java-maven':
        run('mvn verify -DskipUTs=true -Dmaven.test.failure.ignore=true', cwd=d)

    elif lang in ('nodejs', 'react', 'angular', 'vue'):
        pkg = open(os.path.join(d, 'package.json')).read() if os.path.isfile(os.path.join(d, 'package.json')) else ''
        if '"test:integration"' in pkg:
            run('npm run test:integration', cwd=d)
        elif '"test:e2e"' in pkg:
            run('npm run test:e2e', cwd=d)

    elif lang == 'go':
        run(f'go test ./... -v -tags=integration '
            f'-json > "{REPORTS_DIR}/go-integration-{safe}.json" 2>&1', cwd=d)

INTTEST_EOF
"""
            }
        }

        // =====================================================================
        // STAGE 6: CycloneDX SBOM Generation (per module + full workspace)
        // =====================================================================
        stage('CycloneDX SBOM Generation') {
            when { expression { params.GENERATE_SBOM } }
            steps {
                sh """
export REPORTS_DIR='${REPORTS_DIR}'
export WORKSPACE='${WORKSPACE}'
python3 <<'SBOM_EOF'
import json, subprocess, os

WORKSPACE   = os.environ['WORKSPACE']
REPORTS_DIR = os.environ['REPORTS_DIR']
SBOM_DIR    = os.path.join(REPORTS_DIR, 'sbom')
os.makedirs(SBOM_DIR, exist_ok=True)
modules     = json.loads(open(os.path.join(REPORTS_DIR, 'modules.json')).read())

def run(cmd, cwd=None):
    print(f'  \\$ {cmd}')
    return subprocess.run(cmd, shell=True, cwd=cwd or WORKSPACE).returncode

for key, m in modules.items():
    lang    = m['language']
    d       = os.path.join(WORKSPACE, m['dir']) if m['dir'] else WORKSPACE
    safe    = key.replace('/', '-')
    print(f'\\n{"="*60}')
    print(f'  [sbom] Module: {key}  lang={lang}')
    print(f'{"="*60}')

    if lang == 'python':
        for dep in m.get('dep_files', []):
            fp = os.path.join(WORKSPACE, dep)
            if not os.path.isfile(fp): continue
            name = os.path.basename(dep)
            dep_safe = dep.replace('/', '-').lstrip('-')
            if name.startswith('requirements') and name.endswith('.txt'):
                run(f'cyclonedx-py requirements -i "{fp}" --output-format json '
                    f'-o "{SBOM_DIR}/sbom-python-{dep_safe}.json"')
                run(f'pip-audit -r "{fp}" --format=cyclonedx-json '
                    f'-o "{SBOM_DIR}/sbom-audit-{dep_safe}.json" 2>/dev/null; '
                    f'pip-audit -r "{fp}" > "{SBOM_DIR}/sbom-audit-{dep_safe}.txt" 2>/dev/null')
        run(f'cyclonedx-py environment --output-format json '
            f'-o "{SBOM_DIR}/sbom-python-env-{safe}.json"')

    elif lang == 'java-maven':
        run('mvn org.cyclonedx:cyclonedx-maven-plugin:2.7.11:makeAggregateBom '
            f'-DoutputFormat=json -DoutputName=sbom-maven-{safe} '
            f'-DoutputDirectory="{SBOM_DIR}" -q', cwd=d)

    elif lang == 'java-gradle':
        run('./gradlew cyclonedxBom 2>/dev/null || gradle cyclonedxBom', cwd=d)
        run(f'cp build/reports/bom.json "{SBOM_DIR}/sbom-gradle-{safe}.json" 2>/dev/null', cwd=d)

    elif lang in ('nodejs', 'react', 'angular', 'vue'):
        run(f'npx @cyclonedx/cyclonedx-npm --output-format JSON '
            f'--output-file "{SBOM_DIR}/sbom-{lang}-{safe}.json" '
            f'--ignore-npm-errors 2>/dev/null || '
            f'npm sbom --sbom-format cyclonedx --omit dev '
            f'> "{SBOM_DIR}/sbom-{lang}-{safe}.json" 2>/dev/null', cwd=d)
        run(f'npm audit --json > "{SBOM_DIR}/npm-audit-{safe}.json" 2>/dev/null', cwd=d)

    elif lang == 'go':
        run(f'cyclonedx-gomod mod -json '
            f'-output "{SBOM_DIR}/sbom-go-{safe}.json"', cwd=d)

    elif lang == 'dotnet':
        import glob
        csproj_files = glob.glob(os.path.join(d, '*.csproj'))
        for cp in csproj_files[:1]:
            cp_safe = os.path.basename(cp).replace('.csproj', '')
            run(f'dotnet CycloneDX "{cp}" --json '
                f'--output "{SBOM_DIR}" --filename "sbom-dotnet-{cp_safe}.json"')

print()
print('  [sbom] Running Trivy full-workspace SBOM (CycloneDX JSON)...')
SBOM_EOF
"""

                // Trivy workspace-wide SBOMs
                sh """
                    trivy fs --format cyclonedx \
                        --output '${REPORTS_DIR}/sbom/sbom-trivy-cyclonedx.json' \
                        '${WORKSPACE}' 2>/dev/null || true

                    trivy fs --format spdx-json \
                        --output '${REPORTS_DIR}/sbom/sbom-trivy-spdx.json' \
                        '${WORKSPACE}' 2>/dev/null || true

                    # ── Human-readable text reports ──────────────────────────
                    trivy fs --format table \
